<odoo>
    <template id="custom_header" inherit_id="website.layout" name="Custom Header">
        <xpath expr="//header[@id='top']" position="replace">
            <div class="o_structure"/>
            <header id="header"
                    t-att-class="'custom-navbar header ' + ('home-header header' if request.httprequest.path == '/' else 'inner-header innerHeader')">
                <nav class="navbar navbar-expand-lg py-3" t-att-style="'background-color: #0056a0 !important;' if request.httprequest.path != '/' else ''">
                    <div class="container-fluid d-flex justify-content-between align-items-center">
                        <a class="navbar-brand" href="/">
                            <img src="/ust_website_home/static/src/images/logo.png" alt="logo" class="blLogo"/>
                            <img src="/ust_website_home/static/src/images/inner-logo.png" alt="logo" class="whtLogo"/>
                        </a>
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                                data-bs-target="#navbarSupportedContent"
                                aria-controls="navbarSupportedContent" aria-expanded="false"
                                aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>

                        <div class="collapse navbar-collapse justify-content-end" id="navbarSupportedContent">
                            <ul class="navbar-nav ms-auto align-items-center d-flex flex-wrap">
                                <t t-foreach="website.menu_id.child_id" t-as="submenu">
                                    <t t-call="website.submenu">
                                        <t t-set="item_class" t-value="'nav-item'"/>
                                        <t t-set="link_class" t-value="'nav-link menu-text'"/>
                                    </t>
                                </t>
                            </ul>

                            <ul class="navbar-nav align-items-center gap-2 flex-shrink-0 ps-lg-5">
                                <t t-call="website.placeholder_header_search_box">
                                    <t t-set="_layout" t-value="'modal'"/>
                                    <t t-set="_input_classes" t-value="'border border-end-0 p-3'"/>
                                    <t t-set="_submit_classes" t-value="'border border-start-0 px-4 bg-o-color-4'"/>
                                    <t t-set="_button_classes" t-value="'o_navlink_background text-reset'"/>
                                </t>
                            </ul>

                            <!-- User Sign In and Dropdown -->
                            <ul style="margin-top: 20px; font-weight: 600;">
                                <t t-call="portal.placeholder_user_sign_in">
                                    <t t-set="_item_class" t-valuef="nav-item ml-lg-auto"/>
                                    <t t-set="_link_class" t-valuef="nav-link font-weight-bold"/>
                                </t>
                                <t t-call="portal.user_dropdown">
                                    <t t-set="_user_name" t-value="true"/>
                                    <t t-set="_item_class" t-valuef="nav-item dropdown ml-lg-auto"/>
                                    <t t-set="_link_class" t-valuef="nav-link font-weight-bold"/>
                                </t>
                            </ul>
                        </div>
                    </div>
                </nav>
            </header>
            <div class="o_structure"/>
        </xpath>
    </template>
</odoo>
