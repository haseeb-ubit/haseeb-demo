<odoo>
    <template id="admission_template" name="Admission Page">
        <t t-call="website.layout">

            <!--<head>
                <meta charset="utf-8"/>
                <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
                <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
                <link rel="shortcut icon" href="favicon.ico" type="/ust_website_programmes/static/src/image/x-icon"/>
                <title>University of Science &amp; Technology</title>
                <link rel="stylesheet" href="/ust_website_programmes/static/src/css/slick.css" type="text/css"/>
                <link rel="stylesheet" href="/ust_website_programmes/static/src/css/stylesheet.css" type="text/css"/>
                <link rel="stylesheet" href="/ust_website_programmes/static/src/css/responsive.css" type="text/css"/>
            </head>-->

            <div class="oe_structure"/>
            <div id="wrap">


                <section class="innerBanner admission bgCover"
                         style="background: url(/ust_website_programmes/static/src/images/admission-banner.jpg) no-repeat center right;">
                    <div class="container flexBox itemCenter">
                        <div class="innerBannerText">
                            <span class="mb-20">Admission &amp; Registration Requirements for international programs
                            </span>
                            <a href="#" class="applyNow">Enroll Now
                                <span class="material-icons">chevron_right</span>
                            </a>
                        </div>
                    </div>
                </section>
                <section class="pt60 pb60">
                    <div class="container">
                        <div class="flexBox introductionBox">
                            <div class="info">
                                <div class="mainHd">Introduction</div>
                                <div class="textBox">
                                    As a leading international institution, UTS has expanded its offering of
                                    international
                                    programmes not only at the national and regional level, but has also extended to
                                    form
                                    collaborative links with international universities in countries such as China,
                                    Malaysia, Turkey, the Netherlands, Germany and Italy. The university has offered a
                                    number of postgraduate and research programmes to Malaysian and other universities,
                                    with
                                    over 400 graduates from these programmes.
                                    <br/>
                                    <br/>
                                    The International Programs Department is responsible for permanent coordination with
                                    universities and scientific institutions that offer scientific programs and
                                    specializations to be taught in the Deanship of Graduate Studies at the University
                                    of
                                    Science and Technology, and for developing or downloading study plans, scientific
                                    materials, and curricula that the department will implement for students studying in
                                    its
                                    academic specializations, and for harmonizing, approximating, and coordinating
                                    between
                                    the systems, regulations, times, and activities of the universities offering study
                                    programs and specializations and between the systems, regulations, times, and
                                    activities
                                    of the University of Science and Technology implementing those programs and
                                    specializations, and developing and formulating schedules of lectures, exams, and
                                    various activities for the specializations and programs affiliated with the
                                    department
                                    and managing and following up on their implementation.
                                </div>
                            </div>
                            <div class="img">
                                <img src="/ust_website_programmes/static/src/images/introduction-img.jpg"
                                     alt="Introduction"/>
                            </div>
                        </div>
                    </div>
                </section>
                <section class="pt60 pb60 bgCover admissionReq"
                         style="background: url(/ust_website_programmes/static/src/images/admission-req-bg.jpg) no-repeat center;">
                    <div class="container">
                        <div class="mainHd whtClr tac">Admission Requirements</div>
                        <ul class="flexBox reqBox">
                            <li>
                                <div class="transparentBox whtClr">
                                    <div class="inner">
                                        <div class="smallHd">PhD Admission Requirements</div>
                                        <ul class="countList">
                                            <li>A copy of the first page of the passport with a validity of at least one
                                                and
                                                a half years.
                                            </li>
                                            <li>White background selfie without glasses</li>
                                            <li>A copy of the Bachelor's degree certificate in English and the original
                                                language.
                                            </li>
                                            <li>A copy of the bachelor's degree transcript in English and the original
                                                language.
                                            </li>
                                            <li>A copy of the master's degree certificate in English and the original
                                                language
                                            </li>
                                            <li>A copy of the transcript of grades for the master's degree in English
                                                and
                                                the original language
                                            </li>
                                            <li>English language certificate (TOEFL or IELTS test) (if available)</li>
                                            <li>Certificate of practical experience (if available)</li>
                                        </ul>
                                    </div>
                                </div>
                            </li>
                            <li>
                                <div class="transparentBox whtClr">
                                    <div class="inner">
                                        <div class="smallHd">Undergraduate Admission Requirements</div>
                                        <ul class="countList">
                                            <li>A copy of all passport pages with a validity of at least one and a half
                                                years.
                                            </li>
                                            <li>White background selfie without glasses</li>
                                            <li>A copy of the high school certificate and transcript in English and the
                                                original language.
                                            </li>
                                            <li>English language certificate (TOEFL or IELTS test) (if available).</li>
                                            <li>Application form</li>
                                            <li>Registration payment receipt</li>
                                        </ul>
                                    </div>
                                </div>
                            </li>
                            <li>
                                <div class="transparentBox whtClr">
                                    <div class="inner">
                                        <div class="smallHd">Admission requirements for master's degree</div>
                                        <ul class="countList">
                                            <li>A copy of the first page of the passport with a validity of at least one
                                                and
                                                a half years.
                                            </li>
                                            <li>White background selfie without glasses</li>
                                            <li>A copy of the Bachelor's degree certificate in English and the original
                                                language.
                                            </li>
                                            <li>A copy of the bachelor's degree transcript in English and the original
                                                language.
                                            </li>
                                            <li>English language certificate (TOEFL or IELTS test) (if available)</li>
                                            <li>Certificate of practical experience (if available)</li>
                                            <li>Thesis or proposal (for research system only)</li>
                                            <li>A copy of the application fee payment receipt</li>
                                        </ul>
                                    </div>
                                </div>
                            </li>
                        </ul>
                    </div>
                </section>
                <section class="pt60 pb60">
                    <div class="container">
                        <div class="enrollBanner"
                             style="background: url(/ust_website_programmes/static/src/images/enroll-banner.jpg) no-repeat center;">
                            <div class="mainHd whtClr">Admission and registration for the academic year 2024/2025 is now
                                open in all university faculties and specializations
                            </div>
                            <div>
                                <a href="#" class="applyNow">Enroll Now
                                    <span class="material-icons">chevron_right</span>
                                </a>
                            </div>
                        </div>
                        <div class="pt60">
                            <div class="mainHd">Browse list of international programs by university</div>
                            <ul class="browseList">
                                <li>
                                    <a href="#">University of Science and Technology Malaysia USIM</a>
                                </li>
                                <li>
                                    <a href="#">Open University of Malaysia OUM</a>
                                </li>
                                <li>
                                    <a href="#">Sultan Zainal Abidin University UNISZA</a>
                                </li>
                                <li>
                                    <a href="#">University of Science Malaysia USM</a>
                                </li>
                                <li>
                                    <a href="#">National University of Malaysia UKM</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </section>
                <section class="pb60">
                    <div class="container">
                        <div class="mainHd">Academic Programmes</div>
                        <ul class="flexBox academiicProgramms">
                            <li>
                                <a href="#" class="img"
                                   style="background: url(/ust_website_programmes/static/src/images/undergraduate-programs.jpg) no-repeat center;">
                                    <img src="/ust_website_programmes/static/src/images/undergraduate-programs.jpg"
                                         alt="Undergraduate Programs"/>
                                    <span>Undergraduate
                                        <br/>
                                        Programs
                                    </span>
                                </a>
                            </li>
                            <li>
                                <a href="#" class="img"
                                   style="background: url(/ust_website_programmes/static/src/images/postgraduate-programs.jpg) no-repeat center;">
                                    <img src="/ust_website_programmes/static/src/images/postgraduate-programs.jpg"
                                         alt="Postgraduate Programs"/>
                                    <span>Postgraduate
                                        <br/>
                                        Programs
                                    </span>
                                </a>
                            </li>
                            <li>
                                <a href="#" class="img"
                                   style="background: url(/ust_website_programmes/static/src/images/international-programs.jpg) no-repeat center;">
                                    <img src="/ust_website_programmes/static/src/images/international-programs.jpg"
                                         alt="International Programs"/>
                                    <span>International
                                        <br/>
                                        Programs
                                    </span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </section>
                <div class="oe_structure"/>
            </div>

            <script src="/ust_website_programmes/static/src/js/jquery.min.js"></script>
            <script src="/ust_website_programmes/static/src/js/function.js"></script>


        </t>
    </template>
</odoo>