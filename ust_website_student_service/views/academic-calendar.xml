<odoo>
    <template id="academic_calendar_template" name="Academic Calendar Page">
        <t t-call="website.layout">
            <div class="oe_structure"/>
            <div id="wrap">
                <section class="innerBanner bgCover examSchedule"
                         style="background: url(/ust_website_student_service/static/src/images/academic-calendar.jpg) no-repeat center right;">
                    <div class="container flexBox itemCenter">
                        <div class="innerBannerText">
                            <span class="mb-20">Academic-Calendar</span>
                        </div>
                    </div>
                </section>
                <section class="pt60 pb60">
                    <div class="container">
                        <div class="mainHd tac">Academic Calendar for the year 2024 - 2025 AD</div>
                        <div class="tac mt-10">
                            <img src="/ust_website_student_service/static/src/images/calender-img.jpg" alt=""
                                 style="max-width: 50%; display: block; margin: 0 auto;"/>
                        </div>
                    </div>
                </section>
                <div class="oe_structure"/>
                <script src="/ust_website_student_service/static/src/js/jquery.min.js"></script>
                <script src="/ust_website_student_service/static/src/js/function.js"></script>
                <script src="/ust_website_student_service/static/src/js/slick.min.js"></script>
                <script>
                    $('.ipSlider').slick({
                    dots: false,
                    speed: 600,
                    slidesToShow: 5,
                    slidesToScroll: 1,
                    arrows: true,
                    autoplay: true,
                    responsive: [
                    {
                    breakpoint: 1169,
                    settings: {
                    slidesToShow: 4,
                    slidesToScroll: 1,
                    arrows: false,
                    }
                    },
                    {
                    breakpoint: 767,
                    settings: {
                    slidesToShow: 3,
                    slidesToScroll: 1,
                    arrows: false,
                    }
                    },
                    {
                    breakpoint: 479,
                    settings: {
                    slidesToShow: 2,
                    slidesToScroll: 1,
                    arrows: false,
                    }
                    },
                    ]
                    });
                    $('.blogList').slick({
                    dots: false,
                    speed: 600,
                    slidesToShow: 4,
                    slidesToScroll: 1,
                    arrows: true,
                    autoplay: true,
                    responsive: [
                    {
                    breakpoint: 1169,
                    settings: {
                    slidesToShow: 3,
                    slidesToScroll: 1,
                    arrows: false,
                    }
                    },
                    {
                    breakpoint: 767,
                    settings: {
                    slidesToShow: 2,
                    slidesToScroll: 1,
                    arrows: false,
                    }
                    },
                    {
                    breakpoint: 479,
                    settings: {
                    slidesToShow: 1,
                    slidesToScroll: 1,
                    arrows: false,
                    }
                    },
                    ]
                    });
                </script>
            </div>
        </t>
    </template>
</odoo>