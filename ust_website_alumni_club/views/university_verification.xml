<odoo>
    <template id="university_verification_template" name="University Verification Page">
        <t t-call="website.layout">

          <!--  <xpath expr="." position="inside">
                <meta charset="utf-8"/>
                <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
                <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
                <link rel="shortcut icon" href="favicon.ico" type="/ust_website_alumni_club/static/src/image/x-icon"/>
                <title>University of Science &amp; Technology</title>
                <link rel="stylesheet" href="/ust_website_alumni_club/static/src/css/stylesheet.css" type="text/css"/>
