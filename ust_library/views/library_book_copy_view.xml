<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_copy_tree" model="ir.ui.view">
        <field name="name">library.book.copy.tree</field>
        <field name="model">library.book.copy</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="book_id"/>
                <field name="location"/>
                <field name="status" widget="badge"/>
                <field name="current_borrower_id"/>
                <field name="next_available_date"/>
            </list>
        </field>
    </record>

    <record id="view_library_copy_form" model="ir.ui.view">
        <field name="name">library.book.copy.form</field>
        <field name="model">library.book.copy</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="book_id"/>
                            <field name="location"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="book_price"/>
                            <field name="current_borrower_id" readonly="1"/>
                            <field name="next_available_date" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_library_copy" model="ir.actions.act_window">
        <field name="name">Book Copies</field>
        <field name="res_model">library.book.copy</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
