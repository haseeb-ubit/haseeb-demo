<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_borrow_tree" model="ir.ui.view">
        <field name="name">library.borrow.tree</field>
        <field name="model">library.borrow</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="student_id"/>
                <field name="book_id"/>
                <field name="copy_id"/>
                <field name="request_date"/>
                <field name="expected_return_date"/>
                <field name="late_days"/>
                <field name="penalty_amount"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_library_borrow_form" model="ir.ui.view">
        <field name="name">library.borrow.form</field>
        <field name="model">library.borrow</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'request'" groups="ust_library.group_library_manager"/>
                    <button name="action_mark_returned" string="Mark Returned" type="object" class="oe_highlight" invisible="state not in ['borrowed', 'overdue']" groups="ust_library.group_library_manager"/>
                    <button name="action_mark_lost" string="Mark Lost" type="object" class="btn-danger" invisible="state not in ['borrowed', 'overdue']" groups="ust_library.group_library_manager"/>
                    <button name="action_mark_damaged" string="Mark Damaged" type="object" class="btn-warning" invisible="state not in ['borrowed', 'overdue']" groups="ust_library.group_library_manager"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ['returned', 'cancelled']"/>
                    <field name="state" widget="statusbar" statusbar_visible="request,borrowed,overdue,returned,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="student_id" readonly="state != 'request'"/>
                            <field name="copy_id" readonly="state != 'request'"/>
                            <field name="book_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="request_date" readonly="1"/>
                            <field name="borrow_date" readonly="1"/>
                            <field name="expected_return_date" readonly="state != 'request'"/>
                            <field name="return_date" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Penalty &amp; Late Info">
                            <field name="late_days" readonly="1"/>
                            <field name="penalty_amount" readonly="1"/>
                        </group>
                        <group string="Return Condition" invisible="state not in ['borrowed', 'overdue', 'returned']">
                            <field name="return_condition"/>
                            <field name="replacement_cost" readonly="1"/>
                            <field name="replacement_paid"/>
                            <field name="incident_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_library_borrow_search" model="ir.ui.view">
        <field name="name">library.borrow.search</field>
        <field name="model">library.borrow</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="student_id"/>
                <field name="book_id"/>
                <filter name="state_request" string="Requests" domain="[('state','=','request')]"/>
                <filter name="state_borrowed" string="Borrowed" domain="[('state','=','borrowed')]"/>
                <filter name="state_overdue" string="Overdue" domain="[('state','=','overdue')]"/>
                <filter name="state_returned" string="Returned" domain="[('state','=','returned')]"/>
            </search>
        </field>
    </record>

    <record id="action_library_borrow" model="ir.actions.act_window">
        <field name="name">Borrows</field>
        <field name="res_model">library.borrow</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_library_borrow_search"/>
    </record>

    <record id="action_library_borrow_requests" model="ir.actions.act_window">
        <field name="name">Borrow Requests</field>
        <field name="res_model">library.borrow</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'request')]</field>
    </record>

    <record id="action_library_borrow_overdue" model="ir.actions.act_window">
        <field name="name">Overdue Borrows</field>
        <field name="res_model">library.borrow</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'overdue')]</field>
    </record>

    <record id="view_library_reservation_tree" model="ir.ui.view">
        <field name="name">library.reservation.tree</field>
        <field name="model">library.reservation</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="student_id"/>
                <field name="book_id"/>
                <field name="copy_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_library_reservation_form" model="ir.ui.view">
        <field name="name">library.reservation.form</field>
        <field name="model">library.reservation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" string="Activate" type="object" class="oe_highlight" invisible="state != 'requested'" groups="ust_library.group_library_manager"/>
                    <button name="action_done" string="Mark Done" type="object" invisible="state not in ['requested', 'active']" groups="ust_library.group_library_manager"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ['cancelled', 'done']"/>
                    <field name="state" widget="statusbar" statusbar_visible="requested,active,done,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="student_id" readonly="state != 'requested'"/>
                        <field name="book_id" readonly="state != 'requested'"/>
                        <field name="copy_id" readonly="state != 'requested'"/>
                        <field name="start_date" readonly="state != 'requested'"/>
                        <field name="end_date" readonly="state != 'requested'"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_library_reservation" model="ir.actions.act_window">
        <field name="name">Reservations</field>
        <field name="res_model">library.reservation</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_library_penalty_rule_tree" model="ir.ui.view">
        <field name="name">library.penalty.rule.tree</field>
        <field name="model">library.penalty.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="fine_per_day"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_library_penalty_rule_form" model="ir.ui.view">
        <field name="name">library.penalty.rule.form</field>
        <field name="model">library.penalty.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="fine_per_day"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_library_penalty_rule" model="ir.actions.act_window">
        <field name="name">Penalty Rules</field>
        <field name="res_model">library.penalty.rule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
