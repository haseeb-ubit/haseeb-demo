<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_space_tree" model="ir.ui.view">
        <field name="name">library.space.tree</field>
        <field name="model">library.space</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="space_type"/>
                <field name="capacity"/>
                <field name="location"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_library_space_form" model="ir.ui.view">
        <field name="name">library.space.form</field>
        <field name="model">library.space</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="space_type"/>
                            <field name="capacity"/>
                        </group>
                        <group>
                            <field name="location"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bookings">
                            <field name="booking_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="student_id"/>
                                    <field name="date"/>
                                    <field name="start_time" widget="float_time"/>
                                    <field name="end_time" widget="float_time"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_library_space" model="ir.actions.act_window">
        <field name="name">Study Spaces</field>
        <field name="res_model">library.space</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
