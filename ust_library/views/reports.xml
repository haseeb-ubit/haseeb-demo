<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_borrow_pivot_report" model="ir.ui.view">
        <field name="name">library.borrow.pivot.report</field>
        <field name="model">library.borrow</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="book_id" type="row"/>
                <field name="student_id" type="row"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_library_borrow_graph_report" model="ir.ui.view">
        <field name="name">library.borrow.graph.report</field>
        <field name="model">library.borrow</field>
        <field name="arch" type="xml">
            <graph type="bar">
                <field name="book_id" type="row"/>
                <field name="id" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_library_report_most_borrowed" model="ir.actions.act_window">
        <field name="name">Most Borrowed Books</field>
        <field name="res_model">library.borrow</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="view_id" ref="view_library_borrow_pivot_report"/>
        <field name="domain">[('state', 'in', ['borrowed', 'overdue', 'returned'])]</field>
        <field name="context">{'group_by':'book_id'}</field>
    </record>

    <record id="action_library_report_active_borrowers" model="ir.actions.act_window">
        <field name="name">Active Borrowers</field>
        <field name="res_model">library.borrow</field>
        <field name="view_mode">pivot,list</field>
        <field name="view_id" ref="view_library_borrow_pivot_report"/>
        <field name="domain">[('state', 'in', ['borrowed', 'overdue'])]</field>
        <field name="context">{'group_by':'student_id'}</field>
    </record>

    <record id="action_library_report_overdue" model="ir.actions.act_window">
        <field name="name">Overdue Books Report</field>
        <field name="res_model">library.borrow</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="domain">[('state', '=', 'overdue')]</field>
    </record>
</odoo>
