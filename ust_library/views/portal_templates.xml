<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="portal_library_book_detail" name="Book Details">
            <t t-call="portal.portal_layout">
                <!-- <t t-call="ust_library.portal_library_shared_css"/> -->
                <div class="lib-wrap">
                    <a href="/my/library" class="lib-back"><i class="bi bi-arrow-left"/>Back to Catalog</a>

                    <div class="row g-4">
                        <div class="col-md-4">
                            <div class="lib-book-card text-center p-3">
                                <t t-if="book.cover_image">
                                    <img t-attf-src="/web/image?model=library.book&amp;id=#{book.id}&amp;field=cover_image" class="img-fluid rounded-3 mb-3 shadow" style="max-height: 400px;"/>
                                </t>
                                <t t-else="">
                                    <div class="bg-light rounded-3 d-flex align-items-center justify-content-center mb-3" style="height: 350px;">
                                        <i class="bi bi-book text-muted" style="font-size: 5rem;"/>
                                    </div>
                                </t>
                                <h3 class="fw-bold mb-1"><t t-esc="book.name"/></h3>
                                <p class="text-muted"><t t-esc="book.author_ids[0].name if book.author_ids else 'Unknown Author'"/></p>

                                <div t-if="book.ebook_file" class="mt-3">
                                    <a t-attf-href="/my/library/book/#{book.id}/read" class="btn btn-primary rounded-pill w-100 py-2">
                                        <i class="bi bi- eyeglasses me-2"/> Read E-Book
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-8">
                            <div class="lib-card-plain p-4 h-100">
                                <h5 class="fw-bold mb-3 border-bottom pb-2">Book Information</h5>
                                <div class="row mb-4">
                                    <div class="col-6 mb-2">
                                        <label class="small text-muted d-block">Category</label>
                                        <span class="fw-bold"><t t-esc="book.category_id.name"/></span>
                                    </div>
                                    <div class="col-6 mb-2">
                                        <label class="small text-muted d-block">Rating</label>
                                        <span class="text-warning">
                                            <i class="bi bi-star-fill"/> <t t-esc="'%.1f' % (book.avg_rating or 0.0)"/>
                                        </span>
                                    </div>
                                </div>

                                <h5 class="fw-bold mb-3 border-bottom pb-2">Available Copies</h5>
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead>
                                            <tr>
                                                <th>Reference</th>
                                                <th>Status</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="book.copy_ids" t-as="copy">
                                                <tr>
                                                    <td><t t-esc="copy.name"/></td>
                                                    <td>
                                                        <span t-attf-class="badge rounded-pill bg-#{'success' if copy.status == 'available' else 'warning'}">
                                                            <t t-esc="copy.status.capitalize()"/>
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <form t-if="copy.status not in ('lost','damaged')" action="/my/library/reservation/create" method="post" class="d-flex gap-2 align-items-center flex-wrap date-validation-form">
                                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                            <input type="hidden" name="copy_id" t-att-value="copy.id"/>
                                                            <div class="d-flex gap-1">
                                                                <input type="date" name="start_date" required="1" class="form-control form-control-sm rounded-pill future-date-input" style="width:125px;" title="Start Date"/>
                                                                <input type="date" name="end_date" required="1" class="form-control form-control-sm rounded-pill future-date-input" style="width:125px;" title="End Date"/>
                                                            </div>
                                                            <button type="submit" class="btn-action-vvip btn-outline-dark" style="border:1px solid #ddd; background:white; font-size: 0.8rem; padding: 4px 12px; border-radius: 20px;">Reserve</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <script>
                    document.addEventListener('DOMContentLoaded', function() {
                        const today = new Date().toISOString().split('T')[0];
                        document.querySelectorAll('.future-date-input').forEach(input => {
                            input.setAttribute('min', today);
                            if(!input.value) input.value = today;
                        });

                        document.querySelectorAll('.date-validation-form').forEach(form => {
                            const startInput = form.querySelector('input[name="start_date"]');
                            const endInput = form.querySelector('input[name="end_date"]');

                            startInput.addEventListener('change', () => endInput.setAttribute('min', startInput.value));

                            form.addEventListener('submit', function(e) {
                                if (startInput.value > endInput.value) {
                                    e.preventDefault();
                                    alert("End Date cannot be before Start Date.");
                                }
                            });
                        });
                    });
                </script>
            </t>
        </template>

        <template id="portal_library_ebook_reader" name="E-Book Reader">
            <t t-call="portal.portal_layout">
                <t t-call="ust_library.portal_library_shared_css"/>
                <div class="lib-wrap">
                    <a t-attf-href="/my/library/book/#{book.id}" class="lib-back"><i class="bi bi-arrow-left"/>Back to Book</a>
                    <div class="lib-page-header">
                        <div class="lib-icon" style="background:#1a365d;"><i class="bi bi-file-pdf"/></div>
                        <h2><t t-esc="book.name"/> — E-Book Reader</h2>
                    </div>
                    <div style="border:1.5px solid #ddd; border-radius:15px; overflow:hidden; height:80vh; background:white;">
                        <iframe t-attf-src="/web/content/library.book/#{book.id}/ebook_file/#{book.ebook_filename or 'ebook.pdf'}" width="100%" height="100%" style="border:none;"/>
                    </div>
                </div>
            </t>
        </template>

        <template id="portal_library_recommendations" name="Book Recommendations">
            <t t-call="portal.portal_layout">
                <t t-call="ust_library.portal_library_shared_css"/>
                <div class="rec-page-container p-4" style="background: #F8FAFC; min-height: 100vh;">
                    <a href="/my/library" class="btn btn-outline-secondary rounded-pill mb-4"><i class="bi bi-arrow-left"/> Back to Dashboard</a>

                    <div class="d-flex align-items-center gap-3 mb-4 border-bottom pb-3">
                        <div style="background:#1a365d; color:white; padding: 10px; border-radius: 10px;"><i class="bi bi-stars fs-4"/></div>
                        <h2 class="fw-bold m-0" style="font-family: 'Lora', serif;">Book Recommendations</h2>
                    </div>

                    <h5 class="fw-bold mb-3">Popular Books</h5>
                    <div class="row g-3">
                        <t t-foreach="popular_books" t-as="book">
                            <div class="col-md-4">
                                <a t-attf-href="/my/library/book/#{book.id}" class="text-decoration-none">
                                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                                        <div class="row g-0 h-100">
                                            <div class="col-4 bg-light">
                                                <t t-if="book.cover_image">
                                                    <img t-attf-src="/web/image?model=library.book&amp;id=#{book.id}&amp;field=cover_image" class="img-fluid h-100 object-fit-cover"/>
                                                </t>
                                            </div>
                                            <div class="col-8 p-3">
                                                <small class="text-uppercase text-warning fw-bold" style="font-size: 0.6rem;"><t t-esc="book.category_id.name"/></small>
                                                <h6 class="fw-bold text-dark mb-1 d-block text-truncate"><t t-esc="book.name"/></h6>
                                                <div class="text-warning small"><i class="bi bi-star-fill"/> <t t-esc="'%.1f' % (book.avg_rating or 0.0)"/></div>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
        </template>

        <template id="portal_library_purchase_requests" name="My Purchase Requests">
            <t t-call="portal.portal_layout">
                <t t-call="ust_library.portal_library_shared_css"/>
                <div class="p-4" style="background: #F8FAFC; min-height: 100vh;">
                    <a href="/my/library" class="btn btn-outline-secondary rounded-pill mb-4"><i class="bi bi-arrow-left"/> Back</a>

                    <div class="card border-0 shadow-sm rounded-4 p-4 mb-5">
                        <h5 class="fw-bold mb-4"><i class="bi bi-plus-circle-fill me-2 text-primary"/>Request a New Book</h5>
                        <form action="/my/library/purchase-request" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="small fw-bold text-muted text-uppercase">Book Title *</label>
                                    <input type="text" name="book_title" class="form-control" required="1"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="small fw-bold text-muted text-uppercase">Author Name</label>
                                    <input type="text" name="author_name" class="form-control"/>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-dark rounded-pill px-4">Submit Formal Request</button>
                        </form>
                    </div>

                    <h5 class="fw-bold mb-3">Request History</h5>
                    <table class="table bg-white rounded-4 shadow-sm overflow-hidden">
                        <thead class="bg-light">
                            <tr><th>Ref ID</th><th>Title</th><th>Status</th></tr>
                        </thead>
                        <tbody>
                            <t t-foreach="purchase_requests" t-as="pr">
                                <tr>
                                    <td><t t-esc="pr.name"/></td>
                                    <td class="fw-bold"><t t-esc="pr.book_title"/></td>
                                    <td>
                                        <span t-attf-class="badge rounded-pill bg-info text-dark">
                                            <t t-esc="pr.state.capitalize()"/>
                                        </span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </template>

        <template id="portal_library_spaces" name="Library Study Spaces">
            <t t-call="portal.portal_layout">
                <t t-call="ust_library.portal_library_shared_css"/>
                <div class="spaces-container p-4" style="background: #F8FAFC;">
                    <a href="/my/library" class="btn btn-outline-secondary rounded-pill mb-4"><i class="bi bi-arrow-left"/> Dashboard</a>
                    <h2 class="fw-bold mb-4">Study Spaces</h2>
                    <div class="row g-4">
                        <t t-foreach="spaces" t-as="space">
                            <div class="col-md-4">
                                <div class="card h-100 border-0 shadow-sm rounded-4 p-3">
                                    <div style="background: #f1f5f9; width: 50px; height: 50px; border-radius: 12px;" class="d-flex align-items-center justify-content-center mb-3">
                                        <i class="bi bi-people-fill text-primary"/>
                                    </div>
                                    <h5 class="fw-bold"><t t-esc="space.name"/></h5>
                                    <p class="small text-muted"><i class="bi bi-geo-alt me-1"/> <t t-esc="space.location or 'Main Hall'"/></p>
                                    <p class="small fw-bold">Capacity: <t t-esc="space.capacity"/> persons</p>
                                    <a t-attf-href="/my/library/space/#{space.id}/calendar" class="btn btn-dark rounded-pill mt-auto">View Availability</a>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
        </template>

        <template id="portal_library_space_calendar" name="Space Booking Calendar">
            <t t-call="portal.portal_layout">
                <t t-call="ust_library.portal_library_shared_css"/>
                <div class="p-4">
                    <a href="/my/library/spaces" class="btn btn-outline-secondary rounded-pill mb-4">Back to Spaces</a>
                    <h2 class="fw-bold mb-4"><t t-esc="space.name"/> — Calendar</h2>
                    <div class="card border-0 shadow rounded-4 p-4">
                        <form action="/my/library/space/book" method="post" class="row g-3">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="space_id" t-att-value="space.id"/>
                            <div class="col-md-4">
                                <label class="small fw-bold">Date</label>
                                <input type="date" name="date" class="form-control" required="1"/>
                            </div>
                            <div class="col-md-3">
                                <label class="small fw-bold">Start (24h)</label>
                                <input type="number" name="start_time" step="0.5" class="form-control" placeholder="9.0" required="1"/>
                            </div>
                            <div class="col-md-3">
                                <label class="small fw-bold">End (24h)</label>
                                <input type="number" name="end_time" step="0.5" class="form-control" placeholder="11.5" required="1"/>
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary w-100 rounded-pill">Book Slot</button>
                            </div>
                        </form>
                    </div>
                </div>
            </t>
        </template>

        <template id="portal_library_my_space_bookings" name="My Space Bookings">
            <t t-call="portal.portal_layout">
                <t t-call="ust_library.portal_library_shared_css"/>
                <div class="p-4" style="background: #F8FAFC; min-height: 100vh;">
                    <a href="/my/library" class="btn btn-outline-secondary rounded-pill mb-4"><i class="bi bi-arrow-left"/> Back</a>
                    <h2 class="fw-bold mb-4">My Room Bookings</h2>

                    <t t-if="bookings">
                        <div class="table-responsive bg-white rounded-4 shadow-sm">
                            <table class="table align-middle m-0">
                                <thead class="bg-light">
                                    <tr><th>Ref</th><th>Space</th><th>Date</th><th>Time</th><th>Status</th><th>Action</th></tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="bookings" t-as="bk">
                                        <tr>
                                            <td><t t-esc="bk.name"/></td>
                                            <td class="fw-bold"><t t-esc="bk.space_id.name"/></td>
                                            <td><t t-esc="bk.date"/></td>
                                            <td><t t-esc="bk.start_time"/> - <t t-esc="bk.end_time"/></td>
                                            <td><span class="badge rounded-pill bg-success"><t t-esc="bk.state.capitalize()"/></span></td>
                                            <td>
                                                <form t-attf-action="/my/library/space/booking/#{bk.id}/cancel" method="post">
                                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                    <button type="submit" class="btn btn-link text-danger p-0 small">Cancel</button>
                                                </form>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                </div>
            </t>
        </template>
        <template id="portal_library_books" name="My Library Books">
            <t t-call="portal.portal_layout">
                <div id="wrap" class="o_portal_wrap bg-100 py-5">
                    <div class="container">
                        <t t-if="top_rated">
                            <div class="row mb-5">
                                <div class="col-12">
                                    <h3 class="fw-bold text-primary border-bottom pb-2 mb-4">
                                        <i class="fa fa-trophy me-2 text-warning"/>Top Rated Books
                                    </h3>
                                </div>
                                <t t-foreach="top_rated" t-as="top_book">
                                    <div class="col-md-3">
                                        <div class="card border-0 shadow-sm bg-white h-100 overflow-hidden" style="border-radius: 15px;">
                                            <div class="position-absolute top-0 start-0 p-2" style="z-index: 1;">
                                                <span class="badge rounded-pill bg-warning text-dark shadow-sm">
                                                    #<t t-esc="top_book_index + 1"/>
                                                </span>
                                            </div>
                                            <div style="height: 200px; overflow: hidden;">
                                                <img t-if="top_book.cover_image"
                                                     t-attf-src="data:image/png;base64,#{top_book.cover_image}"
                                                     class="w-100 h-100" style="object-fit: cover;"/>
                                                <div t-else="" class="w-100 h-100 bg-primary d-flex align-items-center justify-content-center">
                                                    <i class="fa fa-book fa-2x text-white"/>
                                                </div>
                                            </div>
                                            <div class="card-body p-3 text-center">
                                                <strong class="text-truncate d-block" t-esc="top_book.name"/>
                                                <div class="text-warning small mt-1">
                                                    <t t-foreach="range(5)" t-as="star">
                                                        <i t-attf-class="fa #{'fa-star' if star &lt; top_book.rating else 'fa-star-o'}"/>
                                                    </t>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>
                        <t t-if="favorite_books">
                            <div class="row mb-5">
                                <div class="col-12">
                                    <h3 class="fw-bold text-danger border-bottom pb-2 mb-4">
                                        <i class="fa fa-heart me-2"/>My Saved Books
                                    </h3>
                                </div>
                                <t t-foreach="favorite_books" t-as="fav">
                                    <div class="col-md-2 mb-3"> <a t-attf-href="/my/library/book/#{fav.id}" class="text-decoration-none">
                                            <div class="card shadow-sm border-0 h-100 rounded-3 overflow-hidden">
                                                <div class="bg-primary d-flex align-items-center justify-content-center" style="height: 120px;">
                                                     <img t-if="fav.cover_image" t-attf-src="data:image/png;base64,#{fav.cover_image}" class="w-100 h-100 object-fit-cover"/>
                                                     <i t-else="" class="fa fa-book fa-2x text-white"/>
                                                </div>
                                                <div class="p-2 text-center">
                                                    <small class="fw-bold text-dark text-truncate d-block" t-esc="fav.name"/>
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                </t>
                            </div>
                        </t>
                        <div class="row align-items-center mb-4">
                            <div class="col">
                                <h2 class="fw-bold text-primary">Library Collection</h2>
                                <p class="text-muted">Browse our digital and physical catalog</p>
                            </div>
                        </div>
                        <div class="row mb-5">
                            <div class="col-md-7">
                                <div class="card border-0 shadow-sm rounded-4 h-100">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <h5 class="fw-bold m-0 text-primary">
                                                <i class="fa fa-door-open me-2"/>Study Spaces
                                            </h5>
                                            <a href="/my/library/spaces" class="btn btn-sm btn-outline-primary rounded-pill">View All</a>
                                        </div>
                                        <div class="row g-2">
                                            <t t-foreach="spaces" t-as="space">
                                                <div class="col-6">
                                                    <div class="p-2 border rounded-3 d-flex align-items-center">
                                                        <i t-attf-class="fa fa-circle me-2 #{'text-success' if space.is_available else 'text-danger'}" style="font-size: 0.6rem;"/>
                                                        <span class="small fw-bold"><t t-esc="space.name"/></span>
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-5">
                                <div class="card border-0 shadow-sm rounded-4 h-100 text-white" style="background: #1a237e;">
                                    <div class="card-body">
                                        <h5 class="fw-bold mb-3"><i class="fa fa-calendar-check me-2"/>My Schedule</h5>
                                        <t t-if="bookings">
                                            <t t-foreach="bookings" t-as="bk">
                                                <div class="p-2 mb-2 rounded" style="background: rgba(255,255,255,0.1);">
                                                    <div class="d-flex justify-content-between small">
                                                        <span><t t-esc="bk.space_id.name"/></span>
                                                        <span class="text-warning"><t t-esc="bk.start_time"/>:00</span>
                                                    </div>
                                                </div>
                                            </t>
                                        </t>
                                        <t t-else="">
                                            <div class="text-center opacity-75 py-3">
                                                <i class="fa fa-calendar-o mb-2"/>
                                                <p class="small mb-0">No bookings today</p>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <t t-if="books">
                                <t t-foreach="books" t-as="book">
                                    <div class="col-md-3 mb-4">
                                        <a t-attf-href="/my/library/book/#{book.id}" class="text-decoration-none text-dark h-100">
                                            <div class="card shadow-sm border-0 h-100 o_library_book_card">

                                                <div class="position-relative">
                                                    <button type="object" name="toggle_favorite"
                                                            t-attf-class="btn btn-sm position-absolute top-0 end-0 m-2 #{'text-danger' if request.env.user in book.favorite_user_ids else 'text-white'}"
                                                            style="z-index: 10; background: rgba(0,0,0,0.3); border-radius: 50%;">
                                                        <i class="fa fa-heart"/>
                                                    </button>
                                                    <img t-if="book.cover_image"
                                                         t-attf-src="data:image/png;base64,#{book.cover_image}"
                                                         class="card-img-top"
                                                         style="height: 300px; object-fit: cover; border-radius: 8px 8px 0 0;"/>
                                                    <div t-else="" class="card-img-top d-flex align-items-center justify-content-center"
                                                         style="height: 300px; border-radius: 8px 8px 0 0; background-color: #1a237e !important;">
                                                        <i class="fa fa-book fa-4x text-white"/>
                                                    </div>
                                                </div>

                                                <div class="card-body d-flex flex-column">
                                                    <h6 class="fw-bold mb-1 text-truncate" t-esc="book.name"/>
                                                    <div class="small text-muted mb-2">
                                                        <i class="fa fa-tag me-1"/> <span t-esc="book.category_id.name"/>
                                                    </div>

                                                    <div class="mt-auto pt-2 border-top">
                                                        <div class="text-warning small">
                                                            <t t-foreach="range(5)" t-as="num">
                                                                <i t-attf-class="fa #{'fa-star' if num &lt; book.rating else 'fa-star-o'}"/>
                                                            </t>
                                                            <span class="text-muted ms-1" t-esc="book.rating"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="col-12">
                                    <div class="alert alert-info shadow-sm text-center py-5">
                                        <i class="fa fa-search fa-3x mb-3 text-muted"/>
                                        <p class="mb-0">No books available in the library yet.</p>
                                    </div>
                                </div>
                            </t>
                        </div>

                        <div class="d-flex justify-content-center mt-4">
                            <t t-call="portal.pager"/>
                        </div>
                    </div>
                </div>
            </t>
        </template>


        <template id="portal_my_home_library" inherit_id="portal.portal_my_home" priority="20">
            <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="title">Books Catalog</t>
                    <t t-set="url" t-value="'/my/library/books'"/>
                    <t t-set="placeholder_count" t-value="book_count"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="title">Study Spaces</t>
                    <t t-set="url" t-value="'/my/library/spaces'"/>
                </t>
                <div class="o_portal_chatter mt-5">
