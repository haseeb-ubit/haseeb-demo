<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_space_booking_tree" model="ir.ui.view">
        <field name="name">library.space.booking.tree</field>
        <field name="model">library.space.booking</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="student_id"/>
                <field name="space_id"/>
                <field name="date"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'requested'"
                       decoration-success="state == 'confirmed'"
                       decoration-muted="state in ('cancelled', 'completed')"/>
            </list>
        </field>
    </record>

    <record id="view_library_space_booking_form" model="ir.ui.view">
        <field name="name">library.space.booking.form</field>
        <field name="model">library.space.booking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="oe_highlight" invisible="state != 'requested'"
                            groups="ust_library.group_library_manager"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('cancelled', 'completed')"/>
                    <button name="action_complete" string="Complete" type="object"
                            invisible="state != 'confirmed'"
                            groups="ust_library.group_library_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="requested,confirmed,completed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="student_id" readonly="state != 'requested'"/>
                            <field name="space_id" readonly="state not in ('requested', 'confirmed')"/>
                        </group>
                        <group>
                            <field name="date" readonly="state not in ('requested', 'confirmed')"/>
                            <field name="start_time" widget="float_time" readonly="state not in ('requested', 'confirmed')"/>
                            <field name="end_time" widget="float_time" readonly="state not in ('requested', 'confirmed')"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_library_space_booking_search" model="ir.ui.view">
        <field name="name">library.space.booking.search</field>
        <field name="model">library.space.booking</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="student_id"/>
                <field name="space_id"/>
                <filter name="filter_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_today" string="Today" domain="[('date', '=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                <group>
                    <filter string="Space" name="group_space" context="{'group_by': 'space_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_library_space_booking_calendar" model="ir.ui.view">
        <field name="name">library.space.booking.calendar</field>
        <field name="model">library.space.booking</field>
        <field name="arch" type="xml">
            <calendar string="Space Bookings" date_start="date" color="space_id" mode="week"
                      event_open_popup="true" quick_create="false">
                <field name="name"/>
                <field name="student_id"/>
                <field name="space_id"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
            </calendar>
        </field>
    </record>

    <record id="action_library_space_booking" model="ir.actions.act_window">
        <field name="name">Space Bookings</field>
        <field name="res_model">library.space.booking</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="search_view_id" ref="view_library_space_booking_search"/>
    </record>
</odoo>
