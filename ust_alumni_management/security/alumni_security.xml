<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Security Groups -->
    <record id="privilege_alumni" model="res.groups.privilege">
        <field name="name">Alumni Management</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
    </record>

     <record id="group_alumni_manager" model="res.groups">
        <field name="name">Alumni Manager</field>
        <field name="privilege_id" ref="ust_alumni_management.privilege_alumni"/>
        <field name="comment">Full access to alumni management system</field>
    </record>

    <record id="group_alumni_user" model="res.groups">
        <field name="name">Alumni User</field>
        <field name="privilege_id" ref="ust_alumni_management.privilege_alumni"/>
        <field name="comment">Read and create access to alumni records</field>
    </record>

    <!-- Record Rules -->
    <!-- Alumni can only see/edit their own profile -->
    <record id="rule_alumni_profile_own" model="ir.rule">
        <field name="name">Alumni: own profile only</field>
        <field name="model_id" ref="model_alumni_profile"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
    </record>

    <!-- Portal users can edit their own profile including academic fields -->
    <record id="rule_alumni_profile_portal_readonly_academic" model="ir.rule">
        <field name="name">Alumni: portal own profile access</field>
        <field name="model_id" ref="model_alumni_profile"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
    </record>

    <!-- Public users can only see published achievements -->
    <record id="rule_alumni_achievement_public" model="ir.rule">
        <field name="name">Alumni Achievement: public published only</field>
        <field name="model_id" ref="model_alumni_achievement"/>
        <field name="groups" eval="[(4, ref('base.group_public'))]"/>
        <field name="domain_force">[('is_verified', '=', True)]</field>
    </record>

    <!-- Alumni can only see their own employment records -->
    <record id="rule_alumni_employment_own" model="ir.rule">
        <field name="name">Alumni Employment: own records only</field>
        <field name="model_id" ref="model_alumni_employment"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('alumni_id.user_id', '=', user.id)]</field>
    </record>

    <!-- Alumni can only see their own achievements -->
    <record id="rule_alumni_achievement_own" model="ir.rule">
        <field name="name">Alumni Achievement: own records only</field>
        <field name="model_id" ref="model_alumni_achievement"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('alumni_id.user_id', '=', user.id)]</field>
    </record>

    <!-- Public users can only see published alumni profiles -->
    <record id="rule_alumni_profile_public" model="ir.rule">
        <field name="name">Alumni Profile: public access</field>
        <field name="model_id" ref="model_alumni_profile"/>
        <field name="groups" eval="[(4, ref('base.group_public'))]"/>
        <field name="domain_force">[('active', '=', True)]</field>
    </record>

    <!-- Alumni User Group Record Rules -->
    <!-- Alumni User: own profile only -->
    <record id="rule_alumni_profile_alumni_user" model="ir.rule">
        <field name="name">Alumni User: own profile only</field>
        <field name="model_id" ref="model_alumni_profile"/>
        <field name="groups" eval="[(4, ref('ust_alumni_management.group_alumni_user'))]"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
    </record>

    <!-- Alumni User: own employment only -->
    <record id="rule_alumni_employment_alumni_user" model="ir.rule">
        <field name="name">Alumni User: own employment only</field>
        <field name="model_id" ref="model_alumni_employment"/>
        <field name="groups" eval="[(4, ref('ust_alumni_management.group_alumni_user'))]"/>
        <field name="domain_force">[('alumni_id.user_id', '=', user.id)]</field>
    </record>

    <!-- Alumni User: own achievements only -->
    <record id="rule_alumni_achievement_alumni_user" model="ir.rule">
        <field name="name">Alumni User: own achievements only</field>
        <field name="model_id" ref="model_alumni_achievement"/>
        <field name="groups" eval="[(4, ref('ust_alumni_management.group_alumni_user'))]"/>
        <field name="domain_force">[('alumni_id.user_id', '=', user.id)]</field>
    </record>
</odoo>
