<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Portal Home Link -->
    <template id="portal_alumni_link" inherit_id="portal.portal_my_home" name="Portal Alumni Link">
        <xpath expr="//div[@id='portal_common_category']" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">My Alumni Profile</t>
                <t t-set="text">View and manage your alumni profile details</t>
                <t t-set="url" t-value="'/my/alumni/profile'"/>
                <t t-set="config_card" t-value="True"/>
            </t>
        </xpath>
    </template>

    <!-- Main Alumni Profile Portal Page -->
    <template id="portal_alumni_profile" name="Alumni Profile Portal">
        <t t-call="website.layout">
            <t t-set="title">My Alumni Profile</t>
            <div id="wrap" class="oe_structure oe_empty bg-white pb-5 portal_alumni_profile">
                <div class="container mt-5">
                    <div class="row mb-4">
                        <div class="col-12 text-center">
                            <h2 class="font-weight-light text-dark mb-2">My Alumni Profile</h2>
                            <p class="text-muted font-weight-light">Manage your personal information, employment history, and achievements.</p>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <div class="card shadow-sm border-0 rounded-lg overflow-hidden bg-light">
                                <div class="card-header border-bottom-0 pt-4 pb-0 px-4 bg-transparent">
                                    <ul class="nav nav-tabs border-bottom-0" role="tablist">
                                        <li class="nav-item">
                                            <a class="nav-link active font-weight-medium border-0 rounded-top" data-bs-toggle="tab" href="#general_info" role="tab">
                                                <i class="fa fa-user me-1"/> General Information
                                            </a>
                                        </li>
                                        <li class="nav-item">
                                            <a class="nav-link font-weight-medium border-0 rounded-top" data-bs-toggle="tab" href="#employment" role="tab">
                                                <i class="fa fa-briefcase me-1"/> Employment
                                            </a>
                                        </li>
                                        <li class="nav-item">
                                            <a class="nav-link font-weight-medium border-0 rounded-top" data-bs-toggle="tab" href="#achievements" role="tab">
                                                <i class="fa fa-trophy me-1"/> Achievements
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                                
                                <div class="card-body p-4 bg-white rounded-bottom shadow-sm">
                                    <div class="tab-content">
                                        <!-- General Information Tab -->
                                        <div class="tab-pane fade show active" id="general_info" role="tabpanel">
                                            <t t-call="ust_alumni_management.portal_alumni_general_info"/>
                                        </div>
                                        
                                        <!-- Employment Tab -->
                                        <div class="tab-pane fade" id="employment" role="tabpanel">
                                            <t t-call="ust_alumni_management.portal_alumni_employment"/>
                                        </div>
                                        
                                        <!-- Achievements Tab -->
                                        <div class="tab-pane fade" id="achievements" role="tabpanel">
                                            <t t-call="ust_alumni_management.portal_alumni_achievements"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Render Add Modals at bottom of page -->
            <t t-call="ust_alumni_management.portal_alumni_add_employment_modal"/>
            <t t-call="ust_alumni_management.portal_alumni_add_achievement_modal"/>
            
            <!-- JS fix for modals in portal view (fallbacks if Boostrap 5 data-bs-target fails) -->
            <script type="text/javascript">
                document.addEventListener('DOMContentLoaded', function() {
                    const addEmpBtn = document.getElementById('btn-add-emp');
                    if (addEmpBtn) {
                        addEmpBtn.addEventListener('click', function() {
                            const empModal = new bootstrap.Modal(document.getElementById('addEmploymentModal'));
                            empModal.show();
                        });
                    }
                    
                    const addAchieveBtn = document.getElementById('btn-add-achieve');
                    if (addAchieveBtn) {
                        addAchieveBtn.addEventListener('click', function() {
                            const achieveModal = new bootstrap.Modal(document.getElementById('addAchievementModal'));
                            achieveModal.show();
                        });
                    }
                });
            </script>
        </t>
    </template>

    <!-- General Information Section -->
    <template id="portal_alumni_general_info" name="Portal Alumni General Info">
        <form method="post" action="/my/alumni/profile/update" enctype="multipart/form-data" class="oe_form">
            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
            <input type="hidden" name="section" value="general"/>
            
            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm rounded-lg mb-4">
                        <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                            <h5 class="mb-0 text-dark font-weight-bold"><i class="fa fa-info-circle text-primary me-2"/> Personal Details</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small text-uppercase font-weight-bold">Full Name</label>
                                    <input type="text" name="name" t-att-value="alumni.name" class="form-control form-control-lg bg-light border-0" required="1"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small text-uppercase font-weight-bold">Email</label>
                                    <input type="email" name="email" t-att-value="alumni.email" class="form-control form-control-lg bg-light border-0" required="1"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small text-uppercase font-weight-bold">Phone</label>
                                    <input type="text" name="phone" t-att-value="alumni.phone" class="form-control bg-light border-0"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small text-uppercase font-weight-bold">Mobile</label>
                                    <input type="text" name="mobile" t-att-value="alumni.mobile" class="form-control bg-light border-0"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small text-uppercase font-weight-bold">Date of Birth</label>
                                    <input type="date" name="date_of_birth" t-att-value="alumni.date_of_birth" class="form-control bg-light border-0"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small text-uppercase font-weight-bold">Nationality</label>
                                    <select name="nationality_id" class="form-select form-control bg-light border-0">
                                        <option value="">-- Select --</option>
                                        <t t-foreach="request.env['res.country'].search([])" t-as="country">
                                            <option t-att-value="country.id" t-att-selected="alumni.nationality.id == country.id">
                                                <t t-esc="country.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm rounded-lg mb-4">
                        <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                            <h5 class="mb-0 text-dark font-weight-bold"><i class="fa fa-map-marker text-danger me-2"/> Address Information</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="row">
                                <div class="col-12 mb-3">
                                    <label class="form-label text-muted small text-uppercase font-weight-bold">Street</label>
                                    <input type="text" name="street" t-att-value="alumni.street" class="form-control bg-light border-0"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small text-uppercase font-weight-bold">City</label>
                                    <input type="text" name="city" t-att-value="alumni.city" class="form-control bg-light border-0"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small text-uppercase font-weight-bold">State</label>
                                    <select name="state_id" class="form-select form-control bg-light border-0">
                                        <option value="">-- Select --</option>
                                        <t t-foreach="request.env['res.country.state'].search([])" t-as="state">
                                            <option t-att-value="state.id" t-att-selected="alumni.state_id.id == state.id">
                                                <t t-esc="state.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small text-uppercase font-weight-bold">ZIP Code</label>
                                    <input type="text" name="zip" t-att-value="alumni.zip" class="form-control bg-light border-0"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small text-uppercase font-weight-bold">Country</label>
                                    <select name="country_id" class="form-select form-control bg-light border-0">
                                        <option value="">-- Select --</option>
                                        <t t-foreach="request.env['res.country'].search([])" t-as="country">
                                            <option t-att-value="country.id" t-att-selected="alumni.country_id.id == country.id">
                                                <t t-esc="country.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm rounded-lg mb-4 text-center">
                        <div class="card-body p-4">
                            <h5 class="mb-4 text-dark font-weight-bold">Profile Picture</h5>
                            <div class="position-relative d-inline-block mb-3">
                                <t t-if="alumni.photo">
                                    <img t-att-src="'/web/image/alumni.profile/%s/photo' % alumni.id" 
                                         class="rounded-circle shadow profile-avatar"/>
                                </t>
                                <t t-else="">
                                    <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center shadow profile-avatar">
                                        <i class="fa fa-camera fa-3x text-secondary"/>
                                    </div>
                                </t>
                            </div>
                            <input type="file" name="photo" class="form-control form-control-sm" accept="image/*"/>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm rounded-lg mb-4">
                        <div class="card-body p-4">
                            <h5 class="mb-3 text-dark font-weight-bold"><i class="fa fa-graduation-cap text-info me-2"/> Academic Details</h5>
                            <div class="mb-2 pb-2 border-bottom">
                                <small class="text-muted d-block text-uppercase font-weight-bold">Department</small>
                                <span class="text-dark"><t t-esc="alumni.department_id.name or 'N/A'"/></span>
                            </div>
                            <div class="mb-2 pb-2 border-bottom">
                                <small class="text-muted d-block text-uppercase font-weight-bold">Graduation Year</small>
                                <span class="text-dark"><t t-esc="alumni.graduation_year.strftime('%B %Y') if alumni.graduation_year else 'N/A'"/></span>
                            </div>
                            <div class="mb-2 pb-2 border-bottom">
                                <small class="text-muted d-block text-uppercase font-weight-bold">Degree</small>
                                <span class="text-dark"><t t-esc="alumni.degree or 'N/A'"/></span>
                            </div>
                            <div class="mb-2">
                                <small class="text-muted d-block text-uppercase font-weight-bold">Major</small>
                                <span class="text-dark"><t t-esc="alumni.major or 'N/A'"/></span>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm rounded-lg mb-4">
                        <div class="card-body p-4">
                            <h5 class="mb-3 text-dark font-weight-bold"><i class="fa fa-globe text-primary me-2"/> Web Links</h5>
                            <div class="mb-3">
                                <label class="form-label text-muted small text-uppercase font-weight-bold"><i class="fa fa-linkedin-square text-primary"/> LinkedIn</label>
                                <input type="url" name="linkedin" t-att-value="alumni.linkedin" class="form-control bg-light border-0" placeholder="https://linkedin.com/in/..."/>
                            </div>
                            <div>
                                <label class="form-label text-muted small text-uppercase font-weight-bold"><i class="fa fa-link text-secondary"/> Personal Website</label>
                                <input type="url" name="website" t-att-value="alumni.website" class="form-control bg-light border-0" placeholder="https://..."/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="row mt-4">
                <div class="col-12 text-end text-md-right">
                    <button type="submit" class="btn btn-custom-blue btn-lg rounded-pill px-5 shadow-sm font-weight-bold"><i class="fa fa-save me-2"/> Save Changes</button>
                </div>
            </div>
        </form>
    </template>

    <!-- Employment Section -->
    <template id="portal_alumni_employment" name="Portal Alumni Employment">
        <div class="row mb-4 align-items-center">
            <div class="col-md-8">
                <h4 class="mb-1 text-dark font-weight-bold"><i class="fa fa-briefcase me-2 text-custom-blue"/> Employment History</h4>
                <p class="text-muted small mb-0">Manage your employment records here. Unverified records await administration confirmation.</p>
            </div>
            <div class="col-md-4 text-md-right text-end mt-3 mt-md-0">
                <button type="button" id="btn-add-emp" class="btn btn-custom-blue rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#addEmploymentModal">
                    <i class="fa fa-plus me-1"/> Add Employment
                </button>
            </div>
        </div>
        
        <div class="table-responsive bg-white rounded-lg shadow-sm border border-light">
            <table class="table table-hover mb-0 align-middle">
                <thead class="bg-light text-muted">
                    <tr>
                        <th class="border-0 font-weight-bold text-uppercase small py-3 px-4">Job Title</th>
                        <th class="border-0 font-weight-bold text-uppercase small py-3">Company</th>
                        <th class="border-0 font-weight-bold text-uppercase small py-3">Duration</th>
                        <th class="border-0 font-weight-bold text-uppercase small py-3">Status</th>
                        <th class="border-0 font-weight-bold text-uppercase small py-3 text-end px-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="alumni.employment_ids" t-as="employment">
                        <tr class="cursor-pointer" data-bs-toggle="modal" t-attf-data-bs-target="#viewEmpModal{{employment.id}}">
                            <td class="px-4 py-3">
                                <span class="font-weight-bold text-dark d-block fs-6"><t t-esc="employment.job_title"/></span>
                            </td>
                            <td class="py-3 text-secondary fs-6"><t t-esc="employment.company_name"/></td>
                            <td class="py-3 text-secondary fs-6">
                                <t t-esc="employment.start_date"/> - 
                                <t t-if="employment.end_date"><t t-esc="employment.end_date"/></t>
                                <t t-else=""><span class="badge bg-info text-white rounded-pill px-2 py-1">Present</span></t>
                            </td>
                            <td class="py-3">
                                <t t-if="employment.verification_status == 'verified'">
                                    <span class="badge bg-success text-white rounded-pill px-3 py-1"><i class="fa fa-check-circle me-1"/> Verified</span>
                                </t>
                                <t t-if="employment.verification_status == 'pending_verification'">
                                    <span class="badge bg-warning text-dark rounded-pill px-3 py-1"><i class="fa fa-hourglass-half me-1"/> Pending</span>
                                </t>
                                <t t-if="employment.verification_status == 'rejected'">
                                    <span class="badge bg-danger text-white rounded-pill px-3 py-1"><i class="fa fa-times-circle me-1"/> Rejected</span>
                                </t>
                                <t t-if="employment.verification_status == 'draft'">
                                    <span class="badge bg-secondary text-white rounded-pill px-3 py-1"><i class="fa fa-file-o me-1"/> Draft</span>
                                </t>
                            </td>
                            <td class="py-3 text-end px-4">
                                <t t-if="employment.verification_status == 'draft'">
                                    <span class="text-muted small"><i class="fa fa-info-circle me-1"/>Awaiting admin verification</span>
                                </t>
                            </td>
                        </tr>
                    </t>
                    <t t-if="not alumni.employment_ids">
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa fa-briefcase fa-3x mb-3 text-light"></i>
                                <h5>No employment records found.</h5>
                                <p>Click "Add Employment" to add your work history.</p>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </div>
        
        <!-- View Employment Modals (Rendered outside table to preserve invalid HTML stripping issue) -->
        <t t-foreach="alumni.employment_ids" t-as="employment">
            <div class="modal fade" t-attf-id="viewEmpModal{{employment.id}}" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow">
                        <div class="modal-header bg-light border-0">
                            <h5 class="modal-title font-weight-bold text-dark"><i class="fa fa-briefcase me-2 text-custom-blue"/> Employment Details</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body p-4">
                            <h4 class="font-weight-bold text-dark mb-1"><t t-esc="employment.job_title"/></h4>
                            <h6 class="text-secondary mb-3"><t t-esc="employment.company_name"/></h6>
                            <hr class="my-3"/>
                            <div class="row mb-2">
                                <div class="col-4 text-muted small text-uppercase font-weight-bold">Duration</div>
                                <div class="col-8">
                                    <t t-esc="employment.start_date"/> to 
                                    <t t-if="employment.end_date"><t t-esc="employment.end_date"/></t>
                                    <t t-else="">Present</t>
                                </div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-4 text-muted small text-uppercase font-weight-bold">Status</div>
                                <div class="col-8">
                                    <span t-attf-class="badge {{ 'bg-success' if employment.verification_status == 'verified' else 'bg-warning text-dark' if employment.verification_status == 'pending_verification' else 'bg-secondary' }} text-white rounded-pill px-2 py-1">
                                        <t t-esc="employment.verification_status.replace('_', ' ').title()"/>
                                    </span>
                                </div>
                            </div>
                            <t t-if="employment.description">
                                <div class="row mt-3">
                                    <div class="col-12 text-muted small text-uppercase font-weight-bold mb-1">Description</div>
                                    <div class="col-12"><p class="text-secondary small"><t t-esc="employment.description"/></p></div>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Achievements Section -->
    <template id="portal_alumni_achievements" name="Portal Alumni Achievements">
        <div class="row mb-4 align-items-center">
            <div class="col-md-8">
                <h4 class="mb-1 text-dark font-weight-bold"><i class="fa fa-trophy me-2 text-custom-blue"/> Achievements &amp; Awards</h4>
                <p class="text-muted small mb-0">Showcase your notable honors, certifications, and publications.</p>
            </div>
            <div class="col-md-4 text-md-right text-end mt-3 mt-md-0">
                <button type="button" id="btn-add-achieve" class="btn btn-custom-blue font-weight-bold rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#addAchievementModal">
                    <i class="fa fa-plus me-1"/> Add Achievement
                </button>
            </div>
        </div>
        
        <div class="row g-4">
            <t t-foreach="alumni.achievement_ids" t-as="achievement">
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm rounded-lg hover-elevate transition-hover position-relative overflow-hidden cursor-pointer" data-bs-toggle="modal" t-attf-data-bs-target="#viewAchieveModal{{achievement.id}}">
                        <div class="position-absolute bg-custom-blue" style="top: 0; left: 0; width: 4px; height: 100%;"></div>
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title font-weight-bold text-dark mb-0 pe-2 fs-5"><t t-esc="achievement.title"/></h5>
                                <t t-if="achievement.is_verified">
                                    <span class="badge bg-success text-white rounded-pill shadow-sm"><i class="fa fa-check-circle"/> Verified</span>
                                </t>
                                <t t-else="">
                                    <span class="badge bg-secondary text-white rounded-pill shadow-sm">Pending</span>
                                </t>
                            </div>
                            
                            <div class="mb-2">
                                <span class="badge bg-light text-dark border me-2 py-2 px-3 fs-6"><i class="fa fa-tag text-muted me-1"/> <t t-esc="achievement.achievement_type.replace('_', ' ').title()"/></span>
                                <t t-if="achievement.date_achieved">
                                    <span class="text-muted fs-6"><i class="fa fa-calendar-o me-1"/> <t t-esc="achievement.date_achieved"/></span>
                                </t>
                            </div>
                            
                            <t t-if="achievement.issuer_organization">
                                <p class="mb-2 text-secondary font-weight-medium fs-6"><i class="fa fa-certificate text-muted me-2"/> <t t-esc="achievement.issuer_organization"/></p>
                            </t>
                            <t t-if="achievement.description">
                                <p class="card-text text-muted mt-3 border-top pt-3 fs-6"><t t-esc="achievement.description"/></p>
                            </t>
                        </div>
                    </div>
                </div>
            </t>
            <t t-if="not alumni.achievement_ids">
                <div class="col-12 text-center py-5 bg-white rounded-lg shadow-sm border border-light">
                    <i class="fa fa-trophy fa-4x mb-3 text-light"></i>
                    <h5 class="text-muted">No achievements added yet.</h5>
                    <p class="text-muted mb-4">Adding achievements helps you stand out in the directory.</p>
                </div>
            </t>
        </div>
        
        <!-- View Achievement Modals (Rendered outside grid to preserve invalid HTML stripping issue) -->
        <t t-foreach="alumni.achievement_ids" t-as="achievement">
            <div class="modal fade" t-attf-id="viewAchieveModal{{achievement.id}}" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow">
                        <div class="modal-header bg-light border-0">
                            <h5 class="modal-title font-weight-bold text-dark"><i class="fa fa-trophy me-2 text-custom-blue"/> Achievement Details</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body p-4">
                            <h4 class="font-weight-bold text-dark mb-2"><t t-esc="achievement.title"/></h4>
                            <div class="mb-3">
                                <span class="badge bg-light text-dark border me-2 py-1 px-2"><i class="fa fa-tag text-muted me-1"/> <t t-esc="achievement.achievement_type.replace('_', ' ').title()"/></span>
                                <t t-if="achievement.is_verified">
                                    <span class="badge bg-success text-white rounded-pill shadow-sm"><i class="fa fa-check-circle"/> Verified</span>
                                </t>
                            </div>
                            <hr class="my-3"/>
                            <div class="row mb-2">
                                <div class="col-4 text-muted small text-uppercase font-weight-bold">Date</div>
                                <div class="col-8"><t t-esc="achievement.date_achieved" t-if="achievement.date_achieved"/></div>
                            </div>
                            <t t-if="achievement.issuer_organization">
                                <div class="row mb-2">
                                    <div class="col-4 text-muted small text-uppercase font-weight-bold">Issuer</div>
                                    <div class="col-8"><t t-esc="achievement.issuer_organization"/></div>
                                </div>
                            </t>
                            <t t-if="achievement.description">
                                <div class="row mt-3">
                                    <div class="col-12 text-muted small text-uppercase font-weight-bold mb-1">Description</div>
                                    <div class="col-12"><p class="text-secondary small"><t t-esc="achievement.description"/></p></div>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Verification Success Page -->
    <template id="portal_verification_success" name="Verification Success">
        <t t-call="website.layout">
            <t t-set="title">Verification Successful</t>
            <div class="container mt-5">
                <div class="row">
                    <div class="col-md-8 offset-md-2">
                        <div class="alert alert-success">
                            <h4>Verification Successful!</h4>
                            <p>The employment record has been verified successfully.</p>
                            <p><strong>Job Title:</strong> <t t-esc="employment.job_title"/></p>
                            <p><strong>Company:</strong> <t t-esc="employment.company_name"/></p>
                        </div>
                        <a href="/my/alumni/profile" class="btn btn-primary">Back to Profile</a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Verification Error Page -->
    <template id="portal_verification_error" name="Verification Error">
        <t t-call="website.layout">
            <t t-set="title">Verification Error</t>
            <div class="container mt-5">
                <div class="row">
                    <div class="col-md-8 offset-md-2">
                        <div class="alert alert-danger shadow-sm border-0 rounded">
                            <h4 class="alert-heading"><i class="fa fa-exclamation-triangle me-2"/> Verification Failed</h4>
                            <hr/>
                            <p t-esc="error" class="mb-0"/>
                        </div>
                        <a href="/" class="btn btn-outline-primary rounded-pill px-4 mt-3"><i class="fa fa-home me-1"/> Go to Home</a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Add Employment Modal -->
    <template id="portal_alumni_add_employment_modal" name="Add Employment Modal">
        <div class="modal fade" id="addEmploymentModal" tabindex="-1" aria-labelledby="addEmploymentModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-light border-0">
                        <h5 class="modal-title font-weight-bold text-dark" id="addEmploymentModalLabel"><i class="fa fa-briefcase me-2 text-custom-blue"/> Add Employment Record</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form action="/my/alumni/employment/add" method="post" class="needs-validation">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="modal-body p-4">
                            <div class="row g-3">
                                <div class="col-12 col-md-6 mb-3">
                                    <label class="form-label font-weight-bold">Job Title <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control bg-light" name="job_title" required="1" placeholder="e.g. Software Engineer"/>
                                </div>
                                <div class="col-12 col-md-6 mb-3">
                                    <label class="form-label font-weight-bold">Company Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control bg-light" name="company_name" required="1" placeholder="e.g. Odoo S.A."/>
                                </div>
                                <div class="col-12 mb-3">
                                    <label class="form-label font-weight-bold">Company Website</label>
                                    <input type="url" class="form-control bg-light" name="company_website" placeholder="https://..."/>
                                </div>
                                <div class="col-12 col-md-6 mb-3">
                                    <label class="form-label font-weight-bold">Start Date <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control bg-light" name="start_date" required="1"/>
                                </div>
                                <div class="col-12 col-md-6 mb-3">
                                    <label class="form-label font-weight-bold">End Date</label>
                                    <input type="date" class="form-control bg-light" name="end_date"/>
                                    <small class="text-muted">Leave blank if currently employed here.</small>
                                </div>
                                <div class="col-12"><hr/></div>
                                <div class="col-12 col-md-6 mb-3">
                                    <label class="form-label font-weight-bold">HR Email</label>
                                    <input type="email" class="form-control bg-light" name="hr_email" placeholder="For verification purposes"/>
                                </div>
                                <div class="col-12 col-md-6 mb-3">
                                    <label class="form-label font-weight-bold">Manager Email</label>
                                    <input type="email" class="form-control bg-light" name="gm_email" placeholder="For verification purposes"/>
                                </div>
                                <div class="col-12 mb-3">
                                    <label class="form-label font-weight-bold">Job Description</label>
                                    <textarea class="form-control bg-light" name="description" rows="3" placeholder="Briefly describe your responsibilities..."></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer bg-light border-0">
                            <button type="button" class="btn btn-light rounded-pill px-4 border" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-custom-blue rounded-pill px-4 shadow-sm font-weight-bold"><i class="fa fa-save me-1"/> Save Record</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </template>

    <!-- Add Achievement Modal -->
    <template id="portal_alumni_add_achievement_modal" name="Add Achievement Modal">
        <div class="modal fade" id="addAchievementModal" tabindex="-1" aria-labelledby="addAchievementModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-light border-0">
                        <h5 class="modal-title font-weight-bold text-dark" id="addAchievementModalLabel"><i class="fa fa-trophy me-2 text-custom-blue"/> Add Achievement</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form action="/my/alumni/achievement/add" method="post" enctype="multipart/form-data" class="needs-validation">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="modal-body p-4">
                            <div class="row g-3">
                                <div class="col-12 mb-3">
                                    <label class="form-label font-weight-bold">Achievement Title <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control bg-light" name="title" required="1" placeholder="e.g. Employee of the Year or Published Paper"/>
                                </div>
                                <div class="col-12 col-md-6 mb-3">
                                    <label class="form-label font-weight-bold">Type <span class="text-danger">*</span></label>
                                    <select class="form-select form-control bg-light" name="achievement_type" required="1">
                                        <option value="">-- Select Type --</option>
                                        <option value="award">Award</option>
                                        <option value="promotion">Promotion</option>
                                        <option value="publication">Publication</option>
                                        <option value="research">Research</option>
                                        <option value="community_work">Community Work</option>
                                        <option value="other">Other</option>
                                    </select>
                                </div>
                                <div class="col-12 col-md-6 mb-3">
                                    <label class="form-label font-weight-bold">Date Achieved</label>
                                    <input type="date" class="form-control bg-light" name="date_achieved"/>
                                </div>
                                <div class="col-12 col-md-6 mb-3">
                                    <label class="form-label font-weight-bold">Issuer Organization</label>
                                    <input type="text" class="form-control bg-light" name="issuer_organization" placeholder="e.g. Microsoft"/>
                                </div>
                                <div class="col-12 col-md-6 mb-3">
                                    <label class="form-label font-weight-bold">Certificate / Proof Image</label>
                                    <input type="file" class="form-control bg-light" name="certificate_file" accept="image/*,application/pdf"/>
                                </div>
                                <div class="col-12 mb-3">
                                    <label class="form-label font-weight-bold">Certificate URL (if available online)</label>
                                    <input type="url" class="form-control bg-light" name="certificate_url" placeholder="https://..."/>
                                </div>
                                <div class="col-12 mb-3">
                                    <label class="form-label font-weight-bold">Description</label>
                                    <textarea class="form-control bg-light" name="description" rows="3" placeholder="Briefly describe what this achievement is about..."></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer bg-light border-0">
                            <button type="button" class="btn btn-light rounded-pill px-4 border" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-custom-blue rounded-pill px-4 shadow-sm font-weight-bold"><i class="fa fa-save me-1"/> Save Achievement</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </template>
</odoo>
