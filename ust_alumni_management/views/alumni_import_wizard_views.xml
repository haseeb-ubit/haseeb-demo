<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_alumni_import_wizard_form" model="ir.ui.view">
        <field name="name">alumni.import.wizard.form</field>
        <field name="model">alumni.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Alumni">
                <sheet>
                    <group>
                        <field name="import_type"/>
                        <field name="file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                    </group>
                    <group string="Column Mapping">
                        <field name="name_column"/>
                        <field name="email_column"/>
                        <field name="department_column"/>
                        <field name="graduation_year_column"/>
                        <field name="degree_column"/>
                        <field name="major_column"/>
                        <field name="phone_column"/>
                        <field name="country_column"/>
                    </group>
                    <group string="Preview" invisible="not preview_data">
                        <field name="preview_data" nolabel="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Preview" type="object" name="action_preview" class="btn-secondary"/>
                    <button string="Import" type="object" name="action_import" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_alumni_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Alumni</field>
        <field name="res_model">alumni.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
