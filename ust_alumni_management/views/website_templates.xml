<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Alumni Directory Page -->
    <template id="website_alumni_directory" name="Alumni Directory">
        <t t-call="website.layout">
            <t t-set="title">Alumni Directory</t>
            <style>
                /* ─── Premium Directory CSS ─── */
                @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap');
                body { font-family: 'Inter', sans-serif; background: #f4f6fb; }

                /* ── Hero ── */
                .dir-hero {
                    background: linear-gradient(135deg, #0f2240 0%, #1a365d 50%, #2a4a7f 100%);
                    padding: 52px 0 90px;
                    position: relative;
                    overflow: hidden;
                }
                .dir-hero::before {
                    content: '';
                    position: absolute; inset: 0;
                    background-image:
                        radial-gradient(circle at 20% 50%, rgba(200,168,90,.12) 0%, transparent 55%),
                        radial-gradient(circle at 80% 20%, rgba(255,255,255,.05) 0%, transparent 45%);
                    pointer-events: none;
                }
                /* SVG geometric rings */
                .dir-hero-rings {
                    position: absolute; top: -60px; right: -60px;
                    width: 340px; height: 340px; opacity: .09;
                    pointer-events: none;
                }
                .dir-hero-breadcrumb {
                    font-size: .8rem; color: rgba(255,255,255,.55);
                    margin-bottom: 10px; letter-spacing: .02em;
                }
                .dir-hero-breadcrumb a { color: rgba(255,255,255,.55); text-decoration: none; }
                .dir-hero-breadcrumb a:hover { color: #c8a85a; }
                .dir-hero-breadcrumb span { color: #c8a85a; }
                .dir-hero h1 {
                    color: #fff; font-size: 2.4rem; font-weight: 800;
                    letter-spacing: -.03em; margin-bottom: 8px;
                }
                .dir-hero-sub { color: rgba(255,255,255,.65); font-size: .95rem; }
                .dir-hero-stat {
                    display: inline-flex; align-items: center; gap: 6px;
                    background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.15);
                    border-radius: 30px; padding: 5px 14px;
                    color: rgba(255,255,255,.8); font-size: .8rem; font-weight: 600;
                    backdrop-filter: blur(4px); margin-top: 16px;
                }
                .dir-hero-stat i { color: #c8a85a; }

                /* ── Filter Card ── */
                .dir-filter-card {
                    background: #fff;
                    border-radius: 18px;
                    box-shadow: 0 12px 40px rgba(26,54,93,.13);
                    padding: 22px 26px;
                    position: relative; z-index: 10;
                    margin-top: -44px;
                }
                .dir-filter-card .form-control,
                .dir-filter-card .form-select {
                    border: 1.5px solid #dde3ef; border-radius: 10px;
                    height: 42px; font-size: .88rem; color: #2d3748;
                    background: #f8fafd;
                }
                .dir-filter-card .form-control:focus,
                .dir-filter-card .form-select:focus {
                    border-color: #c8a85a;
                    box-shadow: 0 0 0 3px rgba(200,168,90,.14);
                    background: #fff;
                }
                .dir-filter-card .form-control::placeholder { color: #a0aec0; }
                .btn-dir-filter {
                    background: #1a365d; color: #fff;
                    border: none; border-radius: 10px;
                    height: 42px; font-weight: 700; font-size: .88rem;
                    padding: 0 20px; white-space: nowrap; cursor: pointer;
                    transition: background .18s, box-shadow .18s;
                    box-shadow: 0 4px 12px rgba(26,54,93,.25);
                }
                .btn-dir-filter:hover { background: #c8a85a; box-shadow: 0 4px 14px rgba(200,168,90,.35); color: #fff; }

                /* ── Alumni Card ── */
                .dir-card-col { padding-top: 52px; }
                .alumni-dir-card {
                    background: #fff;
                    border-radius: 20px;
                    border: none;
                    box-shadow: 0 4px 20px rgba(26,54,93,.07);
                    border-top: 4px solid #c8a85a;
                    transition: transform .25s cubic-bezier(.4,0,.2,1),
                                box-shadow .25s cubic-bezier(.4,0,.2,1),
                                border-top-color .25s ease;
                    overflow: visible;
                    height: 100%; min-height: 320px;
                    display: flex; flex-direction: column;
                    position: relative;
                }
                .alumni-dir-card:hover {
                    transform: translateY(-8px);
                    box-shadow: 0 24px 52px rgba(26,54,93,.17);
                    border-top-color: #1a365d;
                }
                .alumni-dir-card:hover .alumni-dir-avatar,
                .alumni-dir-card:hover .alumni-dir-avatar-placeholder {
                    box-shadow: 0 8px 24px rgba(26,54,93,.28);
                    border-color: #c8a85a;
                }

                /* Overlapping avatar — breaks top edge of card */
                .alumni-dir-avatar-wrap {
                    position: absolute;
                    top: -44px; left: 50%;
                    transform: translateX(-50%);
                }
                .alumni-dir-avatar {
                    width: 88px; height: 88px;
                    border-radius: 50%; object-fit: cover;
                    border: 3px solid #1a365d;
                    box-shadow: 0 6px 18px rgba(26,54,93,.2);
                    transition: border-color .25s, box-shadow .25s;
                    background: #edf2f7;
                }
                .alumni-dir-avatar-placeholder {
                    width: 88px; height: 88px;
                    border-radius: 50%;
                    border: 3px solid #1a365d;
                    background: #edf2f7;
                    display: inline-flex; align-items: center; justify-content: center;
                    box-shadow: 0 6px 18px rgba(26,54,93,.15);
                    transition: border-color .25s, box-shadow .25s;
                }

                /* Social icons row */
                .alumni-dir-social { margin-bottom: 6px; }
                .alumni-dir-social a {
                    display: inline-flex; align-items: center; justify-content: center;
                    width: 28px; height: 28px; border-radius: 50%;
                    background: #edf2f7; color: #4a5568;
                    font-size: .78rem; margin: 0 2px;
                    text-decoration: none; transition: background .18s, color .18s;
                }
                .alumni-dir-social a:hover { background: #1a365d; color: #fff; }

                .alumni-dir-name {
                    font-size: 1.1rem; font-weight: 800;
                    color: #1a365d; display: block;
                    text-decoration: none; line-height: 1.25;
                    margin-bottom: 3px;
                    text-transform: capitalize;
                }
                .alumni-dir-name:hover { color: #c8a85a; text-decoration: none; }
                .alumni-dir-dept { font-size: .8rem; color: #718096; font-weight: 500; margin-bottom: 10px; }
                .alumni-dir-tags { margin-bottom: 10px; }
                .alumni-dir-tag {
                    display: inline-block;
                    background: #edf2f7; color: #4a5568;
                    border-radius: 30px; font-size: .73rem;
                    font-weight: 600; padding: 3px 10px; margin: 2px;
                }
                .alumni-dir-tag-gold {
                    display: inline-block;
                    background: #FFF9E6; color: #92640a;
                    border: 1px solid rgba(200,168,90,.4);
                    border-radius: 30px; font-size: .73rem;
                    font-weight: 700; padding: 3px 10px; margin: 2px;
                }

                /* Employment badge — bottom of body, above button */
                .alumni-dir-current {
                    background: #F8F9FC;
                    border-top: 1px solid #e8edf5;
                    padding: 10px 18px;
                    font-size: .8rem; color: #1a365d; font-weight: 600;
                    display: flex; align-items: center; gap: 8px;
                    text-align: left;
                }
                .alumni-dir-current i { color: #c8a85a; flex-shrink: 0; }

                .alumni-dir-body {
                    padding: 56px 20px 14px;
                    flex: 1;
                    display: flex; flex-direction: column; align-items: center; text-align: center;
                }

                /* Pill button (not full-width footer) */
                .btn-dir-view {
                    display: inline-block;
                    background: #1a365d; color: #fff;
                    border-radius: 30px;
                    border: none; font-weight: 700;
                    font-size: .85rem; padding: 10px 26px;
                    text-decoration: none; text-align: center;
                    transition: background .2s, box-shadow .2s, transform .2s;
                    margin: 12px auto 18px;
                    box-shadow: 0 4px 12px rgba(26,54,93,.2);
                }
                .btn-dir-view:hover {
                    background: #c8a85a; color: #fff; text-decoration: none;
                    box-shadow: 0 6px 18px rgba(200,168,90,.35);
                    transform: translateY(-1px);
                }
            </style>
            <div id="wrap" class="oe_structure">
                <!-- Hero Banner -->
                <div class="dir-hero">
                    <!-- SVG geometric rings decoration -->
                    <svg class="dir-hero-rings" viewBox="0 0 340 340" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="170" cy="170" r="160" stroke="white" stroke-width="1.5"/>
                        <circle cx="170" cy="170" r="120" stroke="white" stroke-width="1"/>
                        <circle cx="170" cy="170" r="80" stroke="white" stroke-width=".8"/>
                        <circle cx="170" cy="170" r="40" stroke="white" stroke-width=".6"/>
                    </svg>
                    <div class="container" style="position:relative; z-index:2;">
                        <!-- Breadcrumb -->
                        <div class="dir-hero-breadcrumb">
                            <a href="/">Home</a> <i class="fa fa-angle-right mx-1"/> <a href="#">Alumni</a> <i class="fa fa-angle-right mx-1"/> <span>Directory</span>
                        </div>
                        <h1>Alumni Directory</h1>
                        <p class="dir-hero-sub">Connect with distinguished graduates from across the university.</p>
                        <div class="dir-hero-stat"><i class="fa fa-users"/> Professional Network</div>
                    </div>
                </div>

                <div class="container">
                    <!-- Filter Bar -->
                    <div class="dir-filter-card mb-5">
                        <form method="get" action="/alumni">
                            <div class="row g-2 align-items-center">
                                <div class="col-12 col-md">
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0" style="border:1.5px solid #dde3ef; border-radius:10px 0 0 10px; color:#a0aec0; background:#f8fafd !important;"><i class="fa fa-search"/></span>
                                        <input type="text" name="search" t-att-value="search"
                                               class="form-control border-start-0" placeholder="Search by name or email…" style="border-radius:0 10px 10px 0; border-left:none; height:42px;"/>
                                    </div>
                                </div>
                                <div class="col-6 col-md-auto" style="min-width:170px;">
                                    <select name="department_id" class="form-select" style="height:42px;">
                                        <option value="">All Departments</option>
                                        <t t-foreach="departments" t-as="dept">
                                            <option t-att-value="dept.id" t-att-selected="department_id == dept.id">
                                                <t t-esc="dept.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-6 col-md-auto" style="min-width:125px;">
                                    <select name="graduation_year" class="form-select" style="height:42px;">
                                        <option value="">All Years</option>
                                        <t t-foreach="years" t-as="year">
                                            <option t-att-value="year" t-att-selected="graduation_year == year">
                                                <t t-esc="year"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-6 col-md-auto" style="min-width:125px;">
                                    <select name="degree" class="form-select" style="height:42px;">
                                        <option value="">All Degrees</option>
                                        <t t-foreach="degrees" t-as="deg">
                                            <option t-att-value="deg" t-att-selected="degree == deg">
                                                <t t-esc="deg"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-6 col-md-auto" style="min-width:140px;">
                                    <select name="country_id" class="form-select" style="height:42px;">
                                        <option value="">All Countries</option>
                                        <t t-foreach="countries" t-as="country">
                                            <option t-att-value="country.id" t-att-selected="country_id == country.id">
                                                <t t-esc="country.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-12 col-md-auto">
                                    <button type="submit" class="btn-dir-filter w-100"><i class="fa fa-search me-1"/> Search</button>
                                </div>
                            </div>
                        </form>
                    </div>

                    <!-- Alumni Cards -->
                    <div class="row g-4 mb-5">
                        <t t-foreach="alumni" t-as="alum">
                            <div class="col-md-4 col-sm-6 dir-card-col">
                                <div class="alumni-dir-card">
                                    <!-- Overlapping avatar -->
                                    <div class="alumni-dir-avatar-wrap">
                                        <t t-if="alum.photo">
                                            <img t-att-src="'/web/image/alumni.profile/%s/photo' % alum.id"
                                                 class="alumni-dir-avatar" alt="Alumni Photo"/>
                                        </t>
                                        <t t-else="">
                                            <div class="alumni-dir-avatar-placeholder">
                                                <i class="fa fa-user fa-2x" style="color:#1a365d;"/>
                                            </div>
                                        </t>
                                    </div>

                                    <div class="alumni-dir-body">
                                        <!-- Social icons (LinkedIn + website) -->
                                        <div class="alumni-dir-social">
                                            <t t-if="alum.linkedin">
                                                <a t-att-href="alum.linkedin" target="_blank" title="LinkedIn">
                                                    <i class="fa fa-linkedin"/>
                                                </a>
                                            </t>
                                            <t t-if="alum.website">
                                                <a t-att-href="alum.website" target="_blank" title="Website">
                                                    <i class="fa fa-globe"/>
                                                </a>
                                            </t>
                                        </div>

                                        <!-- Name -->
                                        <a t-attf-href="/alumni/{{ alum.url_slug or alum.id }}" class="alumni-dir-name">
                                            <t t-esc="alum.name"/>
                                        </a>

                                        <!-- Department -->
                                        <t t-if="alum.department_id">
                                            <div class="alumni-dir-dept"><t t-esc="alum.department_id.name"/></div>
                                        </t>

                                        <!-- Degree + Year pills -->
                                        <div class="alumni-dir-tags">
                                            <t t-if="alum.degree">
                                                <span class="alumni-dir-tag"><t t-esc="alum.degree"/></span>
                                            </t>
                                            <t t-if="alum.graduation_year">
                                                <span class="alumni-dir-tag-gold">Class of <t t-esc="alum.graduation_year"/></span>
                                            </t>
                                        </div>

                                        <!-- View Profile Pill Button -->
                                        <a t-attf-href="/alumni/{{ alum.url_slug or alum.id }}" class="btn-dir-view mt-auto">
                                            View Profile <i class="fa fa-arrow-right ms-1"/>
                                        </a>
                                    </div>

                                    <!-- Works At employment badge — above the pill, inside card bottom -->
                                    <t t-if="alum.current_employment_id">
                                        <div class="alumni-dir-current">
                                            <i class="fa fa-briefcase"/>
                                            <span>Works at: <strong><t t-esc="alum.current_employment_id.company_name"/></strong></span>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </t>
                        <t t-if="not alumni">
                            <div class="col-12 text-center py-5">
                                <i class="fa fa-search fa-4x text-muted mb-3"></i>
                                <h4 class="text-muted">No alumni found</h4>
                                <p class="text-muted">Try adjusting your filter criteria.</p>
                            </div>
                        </t>
                    </div>

                    <!-- Pagination -->
                    <t t-if="pager">
                        <div class="row mt-2 mb-5">
                            <div class="col-12 d-flex justify-content-center">
                                <t t-call="website.pager"/>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>


    <!-- Individual Alumni Profile Page -->
    <template id="website_alumni_profile" name="Alumni Profile">
        <t t-call="website.layout">
            <style>
                .profile-wrap {
                    font-family: 'Inter', sans-serif;
                }
                .profile-sidebar-card {
                    border: none;
                    border-radius: 20px !important;
                    box-shadow: 0 10px 30px rgba(0,0,0,0.05) !important;
                    transition: transform 0.3s ease, box-shadow 0.3s ease;
                }
                .profile-sidebar-card:hover {
                    transform: translateY(-5px);
                    box-shadow: 0 15px 35px rgba(0,0,0,0.08) !important;
                }
                .profile-avatar-wrapper img, .profile-avatar-wrapper .rounded-circle {
                    transition: transform 0.5s ease;
                    box-shadow: 0 8px 25px rgba(0,0,0,0.1) !important;
                }
                .profile-avatar-wrapper:hover img, .profile-avatar-wrapper:hover .rounded-circle {
                    transform: scale(1.05);
                }
                .profile-section-card {
                    border: none;
                    border-radius: 20px !important;
                    box-shadow: 0 10px 30px rgba(0,0,0,0.05) !important;
                    transition: transform 0.3s ease, box-shadow 0.3s ease;
                }
                .profile-section-card:hover {
                    box-shadow: 0 15px 35px rgba(0,0,0,0.08) !important;
                }
                .employment-item {
                    border-radius: 12px;
                    transition: background-color 0.3s ease, transform 0.3s ease;
                    border: 1px solid transparent;
                    padding: 15px;
                    margin-left: -15px;
                    margin-right: -15px;
                }
                .employment-item:hover {
                    background-color: #ffffff;
                    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
                    border-color: #e6f0ff;
                    transform: translateX(5px);
                }
                .achievement-card {
                    border-radius: 15px !important;
                    border-left: 5px solid #0F52BA !important;
                    box-shadow: 0 5px 15px rgba(0,0,0,0.03) !important;
                    transition: all 0.3s ease;
                    background: linear-gradient(to right, #ffffff, #fafcfc);
                }
                .achievement-card:hover {
                    transform: translateY(-5px) scale(1.02);
                    box-shadow: 0 12px 25px rgba(0, 50, 150, 0.1) !important;
                    border-left-width: 8px !important;
                }
                .contact-item {
                    transition: background-color 0.3s ease;
                    border-radius: 10px;
                    padding: 8px;
                    margin-left: -8px;
                    margin-right: -8px;
                }
                .contact-item:hover {
                    background-color: #ffffff;
                    box-shadow: 0 4px 10px rgba(0,0,0,0.03);
                }
                .contact-icon {
                    transition: transform 0.3s ease, background-color 0.3s ease, color 0.3s ease;
                }
                .contact-item:hover .contact-icon {
                    transform: scale(1.15) rotate(5deg);
                    background-color: #0F52BA !important;
                    color: white !important;
                }
                .section-title {
                    color: #0F52BA !important;
                    font-weight: 700;
                    position: relative;
                    padding-bottom: 12px;
                    margin-bottom: 25px;
                    border-bottom: 2px solid #ebedf0;
                }
                .section-title::after {
                    content: '';
                    position: absolute;
                    bottom: -2px;
                    left: 0;
                    width: 50px;
                    height: 3px;
                    background-color: #0F52BA;
                    transition: width 0.3s ease;
                    border-radius: 3px;
                }
                .profile-section-card:hover .section-title::after {
                    width: 100px;
                }
                .social-btn {
                    transition: all 0.3s ease;
                    box-shadow: 0 4px 10px rgba(0, 119, 181, 0.3);
                }
                .social-btn:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 6px 15px rgba(0, 119, 181, 0.4);
                }
                .employment-icon {
                    transition: all 0.3s ease;
                }
                .employment-item:hover .employment-icon {
                    background-color: #0F52BA !important;
                    color: white !important;
                    transform: scale(1.1);
                }
            </style>
            <div id="wrap" class="oe_structure profile-wrap">
                <div class="container mt-5">
                    <div class="row">
                        <!-- Sidebar: Profile Overview -->
                        <div class="col-lg-4 col-md-5 mb-4">
                            <div class="profile-sidebar-card shadow-sm bg-white rounded p-4 text-center h-100">
                                <div class="profile-avatar-wrapper mb-3">
                                    <t t-if="alumni.photo">
                                        <img t-att-src="'/web/image/alumni.profile/%s/photo' % alumni.id" 
                                             class="img-fluid rounded-circle shadow-sm profile-avatar"/>
                                    </t>
                                    <t t-else="">
                                        <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center shadow-sm profile-avatar">
                                            <i class="fa fa-user fa-5x text-secondary"/>
                                        </div>
                                    </t>
                                </div>
                                <h3 class="font-weight-bold text-dark mb-1"><t t-esc="alumni.name"/></h3>
                                <t t-if="alumni.department_id">
                                    <p class="text-secondary mb-3"><t t-esc="alumni.department_id.name"/></p>
                                </t>
                                <div class="profile-stats mt-4 px-3 text-left">
                                    <t t-if="alumni.graduation_year">
                                        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                                            <strong>Graduated:</strong> <span class="text-muted"><t t-esc="alumni.graduation_year"/></span>
                                        </div>
                                    </t>
                                    <t t-if="alumni.degree">
                                        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                                            <strong>Degree:</strong> <span class="text-muted"><t t-esc="alumni.degree"/></span>
                                        </div>
                                    </t>
                                    <t t-if="alumni.linkedin">
                                        <div class="mt-4 text-center">
                                            <a t-att-href="alumni.linkedin" target="_blank" class="btn btn-primary social-btn rounded-pill px-4">
                                                <i class="fa fa-linkedin me-1"/> LinkedIn
                                            </a>
                                        </div>
                                    </t>
                                    
                                    <hr class="my-4"/>
                                    
                                    <!-- Contact Information (Merged) -->
                                    <h6 class="font-weight-bold section-title mb-3"><i class="fa fa-address-card me-2"/> Contact Info</h6>
                                    <t t-if="alumni.email">
                                        <div class="mb-2 contact-item">
                                            <div class="d-flex align-items-center">
                                                <div class="contact-icon bg-light rounded-circle text-info d-flex align-items-center justify-content-center me-3">
                                                    <i class="fa fa-envelope"/>
                                                </div>
                                                <div class="contact-text">
                                                    <small class="text-muted d-block text-uppercase font-weight-bold">Email</small>
                                                    <a t-att-href="'mailto:' + alumni.email" class="text-dark font-weight-medium"><t t-esc="alumni.email"/></a>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                    <t t-if="alumni.phone">
                                        <div class="mb-2 contact-item">
                                            <div class="d-flex align-items-center">
                                                <div class="contact-icon bg-light rounded-circle text-success d-flex align-items-center justify-content-center me-3">
                                                    <i class="fa fa-phone"/>
                                                </div>
                                                <div class="contact-text">
                                                    <small class="text-muted d-block text-uppercase font-weight-bold">Phone</small>
                                                    <span class="text-dark font-weight-medium"><t t-esc="alumni.phone"/></span>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                    <t t-if="alumni.city or alumni.country_id">
                                        <div class="mb-2 contact-item">
                                            <div class="d-flex align-items-center">
                                                <div class="contact-icon bg-light rounded-circle text-danger d-flex align-items-center justify-content-center me-3">
                                                    <i class="fa fa-map-marker"/>
                                                </div>
                                                <div class="contact-text">
                                                    <small class="text-muted d-block text-uppercase font-weight-bold">Location</small>
                                                    <span class="text-dark font-weight-medium">
                                                        <t t-if="alumni.city"><t t-esc="alumni.city"/>, </t>
                                                        <t t-if="alumni.country_id"><t t-esc="alumni.country_id.name"/></t>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Main Content -->
                        <div class="col-lg-8 col-md-7">
                            <!-- Employment History -->
                            <t t-if="employments">
                                <div class="profile-section-card shadow-sm bg-white rounded p-4 mb-4 transition-hover">
                                    <h5 class="section-title mb-4"><i class="fa fa-briefcase me-2"/> Employment History</h5>
                                    <div class="employment-list">
                                        <t t-foreach="employments" t-as="emp">
                                            <div class="d-flex align-items-center mb-2 employment-item">
                                                <div class="employment-icon bg-light rounded p-3 me-4 text-primary">
                                                    <i class="fa fa-building fa-2x"/>
                                                </div>
                                                <div>
                                                    <h5 class="font-weight-bold mb-1"><t t-esc="emp.job_title"/></h5>
                                                    <p class="text-secondary mb-1 company-name"><t t-esc="emp.company_name"/></p>
                                                    <small class="text-muted">
                                                        <i class="fa fa-calendar-o me-1"/> <t t-esc="emp.start_date"/> - 
                                                        <t t-if="emp.end_date">
                                                            <t t-esc="emp.end_date"/>
                                                        </t>
                                                        <t t-else="">
                                                            Present
                                                        </t>
                                                        <t t-if="emp.employment_type == 'current'">
                                                            <span class="badge badge-success badge-custom ms-2">Current</span>
                                                        </t>
                                                    </small>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </t>
                            
                            <!-- Achievements -->
                            <t t-if="achievements">
                                <div class="profile-section-card shadow-sm bg-white rounded p-4 mb-4 transition-hover">
                                    <h5 class="section-title mb-4"><i class="fa fa-trophy me-2"/> Achievements</h5>
                                    <div class="row">
                                        <t t-foreach="achievements" t-as="achievement">
                                            <div class="col-md-6 mb-3">
                                                <div class="achievement-card rounded h-100 p-3">
                                                    <h6 class="font-weight-bold text-dark mb-2"><t t-esc="achievement.title"/></h6>
                                                    <p class="text-secondary small mb-2">
                                                        <span class="badge badge-light border text-dark me-1"><t t-esc="achievement.achievement_type.replace('_', ' ').title()"/></span>
                                                        <t t-if="achievement.date_achieved"> - <t t-esc="achievement.date_achieved"/></t>
                                                    </p>
                                                    <t t-if="achievement.issuer_organization">
                                                        <p class="text-muted small mb-2">
                                                            <i class="fa fa-certificate text-warning me-1"/> Issued by: <t t-esc="achievement.issuer_organization"/>
                                                        </p>
                                                    </t>
                                                    <t t-if="achievement.description">
                                                        <p class="mb-0 text-dark small overflow-hidden"><t t-esc="achievement.description"/></p>
                                                    </t>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
