<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_partner_custom_view_form_inherit" model="ir.ui.view">
        <field name="name">res.partner.view.form.inherit.custom</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='email']" position="after">
                <field name="test"/>
                <label for="test" class="oe_inline"/>
            </xpath>
        </field>
    </record>

    <record id="res_partner_custom_view_tree_inherit" model="ir.ui.view">
        <field name="name">res.partner.view.form.inherit.custom</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="test" string="Test"/>
            </xpath>
        </field>
    </record>

    <record id="action_res_partner_custom_form_id" model="ir.actions.act_window">
        <field name="name">Contacts (Form)</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form,kanban,activity</field>
        <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'list', 'view_id': ref('res_partner_custom_view_tree_inherit')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('res_partner_custom_view_form_inherit')})
    ]"/>
        <field name="target">current</field>
    </record>


    <menuitem id="custom_scholarship_master_menu" name="Scholarship Management" sequence="1"/>
    <menuitem id="custom_scholarship_menu" name="Student" parent="custom_scholarship_master_menu" sequence="2"/>
    <menuitem id="student_profile"
              name="Student Profile"
              parent="custom_scholarship_menu"
              action="action_res_partner_custom_form_id"/>
</odoo>
