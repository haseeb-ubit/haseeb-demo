<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Exam Venue List View -->
    <record id="view_exam_venue_tree" model="ir.ui.view">
        <field name="name">elearning.exam.venue.tree</field>
        <field name="model">elearning.exam.venue</field>
        <field name="arch" type="xml">
            <list string="Exam Venues" decoration-info="not active">
                <field name="name"/>
                <field name="code"/>
                <field name="college_id"/>
                <field name="building"/>
                <field name="floor"/>
                <field name="total_rooms"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Exam Venue Form View -->
    <record id="view_exam_venue_form" model="ir.ui.view">
        <field name="name">elearning.exam.venue.form</field>
        <field name="model">elearning.exam.venue</field>
        <field name="arch" type="xml">
            <form string="Exam Venue">
                <header>
                    <button name="toggle_active" type="object" string="Archive" 
                            invisible="active == False" class="btn-secondary"/>
                    <button name="toggle_active" type="object" string="Unarchive" 
                            invisible="active == True" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_venue_rooms">
                            <field name="total_rooms" widget="statinfo" string="Rooms"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Venue Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="college_id" options="{'no_create': True}"/>
                            <field name="building"/>
                            <field name="floor"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="total_rooms" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="address" placeholder="Venue Address"/>
                    </group>
                    <notebook>
                        <page string="Rooms">
                            <field name="room_ids" nolabel="1">
                                <list editable="bottom" create="1" delete="1">
                                    <field name="name"/>
                                    <field name="capacity"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Exam Venue Search View -->
    <record id="view_exam_venue_search" model="ir.ui.view">
        <field name="name">elearning.exam.venue.search</field>
        <field name="model">elearning.exam.venue</field>
        <field name="arch" type="xml">
            <search string="Search Exam Venues">
                <field name="name"/>
                <field name="code"/>
                <field name="college_id"/>
                <field name="building"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Group by College" name="group_by_college"
                        context="{'group_by': 'college_id'}"
                        domain="[]"/>
            </search>
        </field>
    </record>

    <!-- Exam Room List View -->
    <record id="view_exam_room_tree" model="ir.ui.view">
        <field name="name">elearning.exam.room.tree</field>
        <field name="model">elearning.exam.room</field>
        <field name="arch" type="xml">
            <list string="Exam Rooms" decoration-info="not active">
                <field name="display_name"/>
                <field name="venue_id"/>
                <field name="capacity"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Exam Room Form View -->
    <record id="view_exam_room_form" model="ir.ui.view">
        <field name="name">elearning.exam.room.form</field>
        <field name="model">elearning.exam.room</field>
        <field name="arch" type="xml">
            <form string="Exam Room">
                <header>
                    <button name="toggle_active" type="object" string="Archive" 
                            invisible="active == False" class="btn-secondary"/>
                    <button name="toggle_active" type="object" string="Unarchive" 
                            invisible="active == True" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Room Number/Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="venue_id" options="{'no_create': True}"/>
                            <field name="college_id" readonly="1"/>
                            <field name="capacity"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="building" readonly="1"/>
                            <field name="floor" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Exam Room Search View -->
    <record id="view_exam_room_search" model="ir.ui.view">
        <field name="name">elearning.exam.room.search</field>
        <field name="model">elearning.exam.room</field>
        <field name="arch" type="xml">
            <search string="Search Exam Rooms">
                <field name="name"/>
                <field name="display_name"/>
                <field name="venue_id"/>
                <field name="college_id"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Group by Venue" name="group_by_venue"
                        context="{'group_by': 'venue_id'}"
                        domain="[]"/>
                <filter string="Group by College" name="group_by_college"
                        context="{'group_by': 'college_id'}"
                        domain="[]"/>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_exam_venue" model="ir.actions.act_window">
        <field name="name">Exam Venues</field>
        <field name="res_model">elearning.exam.venue</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first exam venue!
            </p>
            <p>
                Exam venues are buildings or locations where exams are conducted.
                You can add multiple rooms to each venue.
            </p>
        </field>
    </record>

    <record id="action_exam_room" model="ir.actions.act_window">
        <field name="name">Exam Rooms</field>
        <field name="res_model">elearning.exam.room</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('venue_id', '=', active_id)]</field>
        <field name="context">{'default_venue_id': active_id if active_model == 'elearning.exam.venue' else False, 'search_default_venue_id': active_id if active_model == 'elearning.exam.venue' else False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first exam room!
            </p>
            <p>
                Exam rooms are individual rooms within a venue where exams take place.
                Each room has a seating capacity.
            </p>
        </field>
    </record>

</odoo>
