<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Requirement List View -->
    <record id="view_requirement_list" model="ir.ui.view">
        <field name="name">elearning.requirement.list</field>
        <field name="model">elearning.requirement</field>
        <field name="arch" type="xml">
            <list string="Requirements">
                <field name="name"/>
                <field name="department_id"/>
                <field name="credit_hours"/>
            </list>
        </field>
    </record>

    <!-- Requirement Form View -->
    <record id="view_requirement_form" model="ir.ui.view">
        <field name="name">elearning.requirement.form</field>
        <field name="model">elearning.requirement</field>
        <field name="arch" type="xml">
            <form string="Requirement">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Requirement Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="course_id" options="{'no_create': True}" domain="[('department_id', '=', department_id)]"/>
                            <field name="requirement_type"/>
                            <field name="department_id" options="{'no_create': True}"/>
                            <field name="college_id" readonly="1"/>
                        </group>
                               <group>
                                   <field name="course_credit_hours" string="CH"/>
                                   <field name="course_code" string="Code"/>
                                   <field name="course_prerequisite" string="Prerequisites"/>
                               </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Requirement Description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Requirement Search View -->
    <record id="view_requirement_search" model="ir.ui.view">
        <field name="name">elearning.requirement.search</field>
        <field name="model">elearning.requirement</field>
        <field name="arch" type="xml">
            <search string="Search Requirements">
                <field name="name"/>
                <field name="requirement_type"/>
                <field name="department_id"/>
                <filter string="Faculty Requirements" name="faculty" domain="[('requirement_type', '=', 'faculty')]"/>
                <filter string="Department Requirements" name="department" domain="[('requirement_type', '=', 'department')]"/>
                <filter string="Program Requirements" name="program" domain="[('requirement_type', '=', 'program')]"/>
                <filter string="Elective Requirements" name="elective" domain="[('requirement_type', '=', 'elective')]"/>
                <filter string="University Requirements" name="university" domain="[('requirement_type', '=', 'university')]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_type" context="{'group_by': 'requirement_type'}"/>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Requirement Actions -->
    <record id="action_requirement" model="ir.actions.act_window">
        <field name="name">Requirements</field>
        <field name="res_model">elearning.requirement</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_requirement_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new requirement
            </p>
            <p>
                Manage academic requirements including faculty, department, program, elective, and university requirements.
            </p>
        </field>
    </record>

    <record id="action_view_department_requirements" model="ir.actions.act_window">
        <field name="name">Department Requirements</field>
        <field name="res_model">elearning.requirement</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('department_id', '=', active_id)]</field>
        <field name="context">{'default_department_id': active_id}</field>
    </record>

</odoo>
