<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend Department Form View to add Courses, Requirements, and Semesters buttons -->
    <record id="view_department_form_inherit" model="ir.ui.view">
        <field name="name">hr.department.form.inherit</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']/button[@name='action_employee_from_department']" position="replace">
                <!-- Remove Employees stat button -->
            </xpath>
            <xpath expr="//div[@name='button_box']/button[@name='action_plan_from_department']" position="replace">
                <!-- Remove Plans stat button -->
            </xpath>
            <xpath expr="//field[@name='manager_id']" position="replace">
                <!-- Manager field removed for eLearning departments -->
            </xpath>
            <xpath expr="//field[@name='parent_id']" position="replace">
                <!-- Parent Department field removed for eLearning departments -->
            </xpath>
            <xpath expr="//field[@name='color']" position="replace">
                <!-- Color field removed for eLearning departments -->
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="object" name="action_view_department_courses">
                    <field name="total_courses" widget="statinfo" string="Courses"/>
                </button>
                <button class="oe_stat_button" type="object" name="action_view_department_timetables" icon="fa-calendar">
                    <field name="total_timetables" widget="statinfo" string="Timetables"/>
                </button>
                <button class="oe_stat_button" type="object" name="action_view_department_noticeboards" icon="fa-bullhorn">
                    <field name="total_noticeboards" widget="statinfo" string="Noticeboard"/>
                </button>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <div class="oe_title">
                    <group>
                        <field name="academic_year_start"/>
                        <field name="academic_year_end"/>
                        <field name="academic_years_count" readonly="1"/>
                        <field name="total_courses" readonly="1"/>
                        <field name="head_of_department_name"/>
                        <field name="website_published" widget="boolean_toggle" options="{'terminology': 'website'}"/>
                        <field name="published_date" readonly="1" invisible="not website_published"/>
                    </group>
                    <div class="oe_avatar" name="department_cover" style="position:absolute; top:20px; right:20px;">
                        <field name="image" widget="image" nolabel="1" class="oe_avatar" options="{'preview_image': 'image'}"/>
                    </div>
                </div>
                <notebook>
                    <page string="Requirements" name="requirements">
                        <notebook>
                            <page string="Faculty Requirements" name="faculty_requirements">
                                <field name="faculty_requirement_ids" context="{'default_requirement_type': 'faculty'}">
                                    <list editable="bottom">
                                         <field name="requirement_type" column_invisible="True"/>
                                        <field name="department_id" column_invisible="True"/>
                                        <field name="course_id" string="Course" options="{'no_create': True}" required="1" domain="[('id', 'in', parent.available_requirement_course_ids)]"/>
                                        <field name="course_credit_hours" string="CH" readonly="1"/>
                                        <field name="course_code" string="Code" readonly="1"/>
                                        <field name="course_prerequisite" string="Pre-Requisites" readonly="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Department Requirements" name="department_requirements">
                                <field name="department_requirement_ids" context="{'default_requirement_type': 'department'}">
                                    <list editable="bottom">
                                        <field name="requirement_type" column_invisible="True"/>
                                        <field name="department_id" column_invisible="True"/>
                                        <field name="course_id" string="Course" options="{'no_create': True}" required="1" domain="[('id', 'in', parent.available_requirement_course_ids)]"/>
                                        <field name="course_credit_hours" string="CH" readonly="1"/>
                                        <field name="course_code" string="Code" readonly="1"/>
                                        <field name="course_prerequisite" string="Pre-Requisites" readonly="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Program Requirements" name="program_requirements">
                                <field name="program_requirement_ids" context="{'default_requirement_type': 'program'}">
                                    <list editable="bottom">
                                        <field name="requirement_type" column_invisible="True"/>
                                        <field name="department_id" column_invisible="True"/>
                                        <field name="course_id" string="Course" options="{'no_create': True}" required="1" domain="[('id', 'in', parent.available_requirement_course_ids)]"/>
                                        <field name="course_credit_hours" string="CH" readonly="1"/>
                                        <field name="course_code" string="Code" readonly="1"/>
                                        <field name="course_prerequisite" string="Pre-Requisites" readonly="1"/>
                                    </list>
                                </field>
                            </page>
                             <page string="University Requirements" name="university_requirements">
                                <field name="university_requirement_ids" context="{'default_requirement_type': 'university'}">
                                   <list editable="bottom">
                                       <field name="requirement_type" column_invisible="True"/>
                                        <field name="department_id" column_invisible="True"/>
