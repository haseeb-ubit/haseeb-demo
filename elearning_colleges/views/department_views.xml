    <record id="view_department_list_inherit_elearning" model="ir.ui.view">
        <field name="name">hr.department.list.elearning</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="replace">
                <list>
                    <field name="name"/>
                    <field name="college_id"/>
                    <field name="website_published" widget="boolean_toggle"/>
                    <field name="published_date"/>
                    <field name="total_courses"/>
                </list>
            </xpath>
        </field>
    </record>
</odoo>
