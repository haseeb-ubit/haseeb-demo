<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Semester List View -->
    <record id="view_semester_list" model="ir.ui.view">
        <field name="name">elearning.semester.list</field>
        <field name="model">elearning.semester</field>
        <field name="arch" type="xml">
            <list string="Semesters">
                <field name="name"/>
                <field name="department_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="is_active"/>
                <button name="action_view_course_outline" type="object" string="Course Outline (EN)" class="oe_link" invisible="not course_id"/>
                <button name="action_view_course_outline_ar" type="object" string="Course Outline (AR)" class="oe_link" invisible="not course_id"/>
            </list>
        </field>
    </record>

    <!-- Semester Form View -->
    <record id="view_semester_form" model="ir.ui.view">
        <field name="name">elearning.semester.form</field>
        <field name="model">elearning.semester</field>
        <field name="arch" type="xml">
            <form string="Semester">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Semester Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="course_id" options="{'no_create': True}" domain="[('department_id', '=', department_id)]"/>
                            <field name="year"/>
                            <field name="semester_number"/>
                            <field name="department_id" options="{'no_create': True}"/>
                            <field name="college_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="course_credit_hours" string="CH"/>
                            <field name="course_code" string="Code"/>
                            <field name="course_prerequisite" string="Prerequisites"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Semester Description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Semester Search View -->
    <record id="view_semester_search" model="ir.ui.view">
        <field name="name">elearning.semester.search</field>
        <field name="model">elearning.semester</field>
        <field name="arch" type="xml">
            <search string="Search Semesters">
                <field name="name"/>
                <field name="year"/>
                <field name="semester_number"/>
                <field name="department_id"/>
                <filter string="Active" name="active" domain="[('is_active', '=', True)]"/>
                <filter string="Y1S1" name="y1s1" domain="[('year', '=', 1), ('semester_number', '=', 1)]"/>
                <filter string="Y1S2" name="y1s2" domain="[('year', '=', 1), ('semester_number', '=', 2)]"/>
                <filter string="Y2S1" name="y2s1" domain="[('year', '=', 2), ('semester_number', '=', 1)]"/>
                <filter string="Y2S2" name="y2s2" domain="[('year', '=', 2), ('semester_number', '=', 2)]"/>
                <group expand="0" string="Group By">
                    <filter string="Year" name="group_year" context="{'group_by': 'year'}"/>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Semester Actions -->
    <record id="action_semester" model="ir.actions.act_window">
        <field name="name">Semesters</field>
        <field name="res_model">elearning.semester</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_semester_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new semester
            </p>
            <p>
                Manage academic semesters including Y1S1, Y1S2, Y2S1, and Y2S2.
            </p>
        </field>
    </record>

    <record id="action_view_department_semesters" model="ir.actions.act_window">
        <field name="name">Department Semesters</field>
        <field name="res_model">elearning.semester</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('department_id', '=', active_id)]</field>
        <field name="context">{'default_department_id': active_id}</field>
    </record>

</odoo>
