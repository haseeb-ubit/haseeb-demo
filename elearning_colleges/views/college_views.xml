<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- College List View -->
    <record id="view_college_tree" model="ir.ui.view">
        <field name="name">elearning.college.tree</field>
        <field name="model">elearning.college</field>
        <field name="arch" type="xml">
            <list string="Colleges" decoration-info="not active">
                <field name="name"/>
                <field name="code"/>
                <field name="dean_name"/>
                <field name="total_students"/>
                <field name="total_faculty"/>
                <field name="total_courses"/>
                <field name="total_departments"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- College Form View -->
    <record id="view_college_form" model="ir.ui.view">
        <field name="name">elearning.college.form</field>
        <field name="model">elearning.college</field>
        <field name="arch" type="xml">
            <form string="College">
                <header>
                    <button name="toggle_active" type="object" string="Archive" 
                            invisible="active == False" class="btn-secondary"/>
                    <button name="toggle_active" type="object" string="Unarchive" 
                            invisible="active == True" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_departments">
                            <field name="total_departments" widget="statinfo" string="Departments"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_college_courses">
                            <field name="total_courses" widget="statinfo" string="Courses"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="College Name"/>
                        </h1>
                        <h3>
                            <field name="code" placeholder="College Code"/>
                        </h3>
                    </div>
                    <group>
                        <group>
                            <field name="dean_name"/>
                            <field name="dean_email"/>
                            <field name="dean_phone"/>
                            <field name="website"/>
                        </group>
                        <group>
                            <field name="established_year"/>
                            <field name="total_students"/>
                            <field name="total_faculty"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="address" placeholder="College Address"/>
                    </group>
                    <group>
                        <field name="description" placeholder="College Description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- College Search View -->
    <record id="view_college_search" model="ir.ui.view">
        <field name="name">elearning.college.search</field>
        <field name="model">elearning.college</field>
        <field name="arch" type="xml">
            <search string="Search Colleges">
                <field name="name"/>
                <field name="code"/>
                <field name="dean_name"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Group by Dean" name="group_by_dean"
                        context="{'group_by': 'dean_name'}"
                        domain="[]"/>
            </search>
        </field>
    </record>

    <!-- College Kanban View -->
    <record id="view_college_kanban" model="ir.ui.view">
        <field name="name">elearning.college.kanban</field>
        <field name="model">elearning.college</field>
        <field name="arch" type="xml">
            <kanban string="Colleges" class="o_kanban_small_column">
                <field name="name"/>
                <field name="code"/>
                <field name="dean_name"/>
                <field name="total_students"/>
                <field name="total_faculty"/>
                <field name="total_courses"/>
                <field name="active"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                        <div class="o_kanban_record_subtitle">
                                            <field name="code"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div class="o_kanban_record_details">
                                        <div t-if="record.dean_name.raw_value">
                                            <strong>Dean:</strong> <field name="dean_name"/>
                                        </div>
                                        <div class="row">
                                            <div class="col-6">
                                                <strong>Students:</strong> <field name="total_students"/>
                                            </div>
                                            <div class="col-6">
                                                <strong>Faculty:</strong> <field name="total_faculty"/>
                                            </div>
                                        </div>
                                        <div>
                                            <strong>Courses:</strong> <field name="total_courses"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- College Action -->
    <record id="action_college" model="ir.actions.act_window">
        <field name="name">Colleges</field>
        <field name="res_model">elearning.college</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_college_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new college
            </p>
            <p>
                Manage colleges and their details including dean information, departments, and courses.
            </p>
        </field>
    </record>

    <!-- College Methods -->
    <record id="action_view_departments" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">hr.department</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('college_id', '=', active_id), ('is_college_department', '=', True)]</field>
        <field name="context">{'default_college_id': active_id, 'default_is_college_department': True}</field>
    </record>

    <record id="action_view_college_courses" model="ir.actions.act_window">
        <field name="name">College Courses</field>
        <field name="res_model">slide.channel</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('college_id', '=', active_id)]</field>
        <field name="context">{'default_college_id': active_id}</field>
    </record>

</odoo>
