<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_college_code" model="ir.sequence">
            <field name="name">College Code</field>
            <field name="code">elearning.college</field>
            <field name="prefix">COL</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
        <record id="seq_course_code" model="ir.sequence">
            <field name="name">Course Code</field>
            <field name="code">elearning.course</field>
            <field name="prefix">CRS</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
    </data>
</odoo>
