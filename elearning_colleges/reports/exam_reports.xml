<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Exam Report Paper Format -->
    <record id="paperformat_exam_report" model="report.paperformat">
        <field name="name">Exam Report - A4 Portrait</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- College Exam Report Action -->
    <record id="action_report_college_exam" model="ir.actions.report">
        <field name="name">College Exam Schedule Report</field>
        <field name="model">elearning.college</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">elearning_colleges.college_exam_report_template</field>
        <field name="report_file">elearning_colleges.college_exam_report_template</field>
        <field name="paperformat_id" ref="elearning_colleges.paperformat_exam_report"/>
    </record>
</odoo>
