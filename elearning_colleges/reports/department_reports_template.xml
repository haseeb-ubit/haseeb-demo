<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- External Layout without Header/Footer -->
    <template id="external_layout_no_header_footer_dept">
        <t t-if="not o" t-set="o" t-value="doc"/>
        <t t-if="not company">
            <t t-if="company_id">
                <t t-set="company" t-value="company_id"/>
            </t>
            <t t-elif="o and 'company_id' in o and o.company_id.sudo()">
                <t t-set="company" t-value="o.company_id.sudo()"/>
            </t>
            <t t-else="else">
                <t t-set="company" t-value="res_company"/>
            </t>
        </t>

        <div t-attf-class="article o_company_#{company.id}_layout"
             style="margin: 0; padding: 0;">
            <t t-out="0"/>
        </div>
    </template>

    <!-- Requirements Report Template -->
    <template id="department_requirements_report_template">
        <t t-call="elearning_colleges.external_layout_no_header_footer_dept">
            <t t-foreach="docs" t-as="doc">
                <main>
                        <div style="font-family: DejaVu Sans, Arial, Tahoma; padding: 20px; margin: 0; position: relative; color: #333; line-height: 1.5;">
                        
                        <!-- Top Section: Logo (Right) and Info (Left) -->
                        <!-- Right Side: UST Logo - Positioned absolutely at top right -->
                        <div style="position: absolute; top: 0; right: 0; text-align: right;">
                            <img t-attf-src="/elearning_colleges/static/src/img/ust_en.png"
                                 alt="UST Logo"
                                 style="width: 200px; height: auto; max-width: 200px;"/>
                        </div>
                        
                        <!-- Left Side: College, Department, Academic Year, Credit Hours -->
                        <div style="width: 60%; margin-bottom: 30px;">
                            <div style="font-size: 18px; font-weight: bold; margin-bottom: 5px;" t-esc="doc.college_id.name if doc.college_id else ''"/>
                            <div style="font-size: 16px; margin-bottom: 5px;" t-esc="doc.name or ''"/>
                            <div style="font-size: 14px; margin-bottom: 5px;">
                                Academic Year: <span t-esc="doc.academic_year_start or ''"/> / <span t-esc="doc.academic_year_end or ''"/>
                            </div>
                            <div style="font-size: 14px;">
                                <t t-set="all_reqs" t-value="doc.faculty_requirement_ids + doc.department_requirement_ids + doc.program_requirement_ids + doc.elective_requirement_ids + doc.university_requirement_ids"/>
                                <t t-set="total_ch" t-value="0"/>
                                <t t-foreach="all_reqs" t-as="r">
                                    <t t-set="ch" t-value="int(r.course_credit_hours) if r.course_credit_hours else 0"/>
                                    <t t-set="total_ch" t-value="total_ch + ch"/>
                                </t>
                                Total Credit Hours: <span t-esc="total_ch"/>
                            </div>
                        </div>

                        <!-- Requirements Sections -->
                        <t t-set="total_credit_hours" t-value="0"/>

                        <!-- University Requirements -->
                        <t t-set="university_reqs" t-value="doc.university_requirement_ids"/>
                        <t t-if="university_reqs">
                            <t t-set="univ_ch" t-value="0"/>
                            <t t-foreach="university_reqs" t-as="r">
                                <t t-set="ch" t-value="int(r.course_credit_hours) if r.course_credit_hours else 0"/>
                                <t t-set="univ_ch" t-value="univ_ch + ch"/>
                            </t>
                            <div style="margin-bottom: 30px;">
                                <h3 style="color: #1a5276; padding: 10px 15px; margin: 0 0 15px 0; font-size: 20px; font-weight: 600;">
                                    First: University Requirements
                                    (<span t-esc="univ_ch"/> Credit Hours)
                                </h3>
                                <table style="width: 100%; border-collapse: collapse; border-radius: 5px; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                                    <thead>
                                        <tr style="background-color: #2980b9; color: white;">
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; width: 5%; text-align: center;">No.</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600;">Course</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; text-align: center;">Code</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; text-align: center;">C.H</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600;">Pre-Requisites</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="university_reqs" t-as="req">
                                            <tr t-attf-style="background-color: {{ req_index % 2 == 0 and '#f9f9f9' or '#ffffff' }};">
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;">
                                                    <span t-esc="req_index + 1"/>
                                                </td>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px;" t-esc="req.course_id.name if req.course_id else ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;" t-esc="req.course_code or ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;" t-esc="req.course_credit_hours or ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px;" t-esc="req.course_prerequisite or '-'"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>

                        <!-- Faculty Requirements -->
                        <t t-set="faculty_reqs" t-value="doc.faculty_requirement_ids"/>
                        <t t-if="faculty_reqs">
                            <t t-set="fac_ch" t-value="0"/>
                            <t t-foreach="faculty_reqs" t-as="r">
                                <t t-set="ch" t-value="int(r.course_credit_hours) if r.course_credit_hours else 0"/>
                                <t t-set="fac_ch" t-value="fac_ch + ch"/>
                            </t>
                            <div style="margin-bottom: 30px;">
                                <h3 style="color: #1a5276; padding: 10px 15px; margin: 0 0 15px 0; font-size: 20px; font-weight: 600;">
                                    Second: Faculty Requirements
                                    (<span t-esc="fac_ch"/> Credit Hours)
                                </h3>
                                <table style="width: 100%; border-collapse: collapse; border-radius: 5px; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                                    <thead>
                                        <tr style="background-color: #2980b9; color: white;">
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; width: 5%; text-align: center;">No.</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600;">Course</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; text-align: center;">Code</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; text-align: center;">C.H</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600;">Pre-Requisites</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="faculty_reqs" t-as="req">
                                            <tr t-attf-style="background-color: {{ req_index % 2 == 0 and '#f9f9f9' or '#ffffff' }};">
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;">
                                                    <span t-esc="req_index + 1"/>
                                                </td>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px;" t-esc="req.course_id.name if req.course_id else ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;" t-esc="req.course_code or ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;" t-esc="req.course_credit_hours or ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px;" t-esc="req.course_prerequisite or '-'"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>

                        <!-- Department Requirements -->
                        <t t-set="department_reqs" t-value="doc.department_requirement_ids"/>
                        <t t-if="department_reqs">
                            <t t-set="dept_ch" t-value="0"/>
                            <t t-foreach="department_reqs" t-as="r">
                                <t t-set="ch" t-value="int(r.course_credit_hours) if r.course_credit_hours else 0"/>
                                <t t-set="dept_ch" t-value="dept_ch + ch"/>
                            </t>
                            <div style="margin-bottom: 30px;">
                                <h3 style="color: #1a5276; padding: 10px 15px; margin: 0 0 15px 0; font-size: 20px; font-weight: 600;">
                                    Third: Compulsory Department Requirements
                                    (<span t-esc="dept_ch"/> Credit Hours)
                                </h3>
                                <table style="width: 100%; border-collapse: collapse; border-radius: 5px; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                                    <thead>
                                        <tr style="background-color: #2980b9; color: white;">
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; width: 5%; text-align: center;">No.</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600;">Course</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; text-align: center;">Code</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; text-align: center;">C.H</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600;">Pre-Requisites</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="department_reqs" t-as="req">
                                            <tr t-attf-style="background-color: {{ req_index % 2 == 0 and '#f9f9f9' or '#ffffff' }};">
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;">
                                                    <span t-esc="req_index + 1"/>
                                                </td>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px;" t-esc="req.course_id.name if req.course_id else ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;" t-esc="req.course_code or ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;" t-esc="req.course_credit_hours or ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px;" t-esc="req.course_prerequisite or '-'"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>

                        <!-- Program Requirements -->
                        <t t-set="program_reqs" t-value="doc.program_requirement_ids"/>
                        <t t-if="program_reqs">
                            <t t-set="prog_ch" t-value="0"/>
                            <t t-foreach="program_reqs" t-as="r">
                                <t t-set="ch" t-value="int(r.course_credit_hours) if r.course_credit_hours else 0"/>
                                <t t-set="prog_ch" t-value="prog_ch + ch"/>
                            </t>
                            <div style="margin-bottom: 30px;">
                                <h3 style="color: #1a5276; padding: 10px 15px; margin: 0 0 15px 0; font-size: 20px; font-weight: 600;">
                                    Fourth: Compulsory Program Requirements
                                    (<span t-esc="prog_ch"/> Credit Hours)
                                </h3>
                                <table style="width: 100%; border-collapse: collapse; border-radius: 5px; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                                    <thead>
                                        <tr style="background-color: #2980b9; color: white;">
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; width: 5%; text-align: center;">No.</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600;">Course</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; text-align: center;">Code</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; text-align: center;">C.H</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600;">Pre-Requisites</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="program_reqs" t-as="req">
                                            <tr t-attf-style="background-color: {{ req_index % 2 == 0 and '#f9f9f9' or '#ffffff' }};">
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;">
                                                    <span t-esc="req_index + 1"/>
                                                </td>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px;" t-esc="req.course_id.name if req.course_id else ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;" t-esc="req.course_code or ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;" t-esc="req.course_credit_hours or ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px;" t-esc="req.course_prerequisite or '-'"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>

                        <!-- Elective Requirements -->
                        <t t-set="elective_reqs" t-value="doc.elective_requirement_ids"/>
                        <t t-if="elective_reqs">
                            <t t-set="elec_ch" t-value="0"/>
                            <t t-foreach="elective_reqs" t-as="r">
                                <t t-set="ch" t-value="int(r.course_credit_hours) if r.course_credit_hours else 0"/>
                                <t t-set="elec_ch" t-value="elec_ch + ch"/>
                            </t>
                            <div style="margin-bottom: 30px;">
                                <h3 style="color: #1a5276; padding: 10px 15px; margin: 0 0 15px 0; font-size: 20px; font-weight: 600;">
                                    Fifth: Elective Requirements
                                    (<span t-esc="elec_ch"/> Credit Hours)
                                </h3>
                                <table style="width: 100%; border-collapse: collapse; border-radius: 5px; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                                    <thead>
                                        <tr style="background-color: #2980b9; color: white;">
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; width: 5%; text-align: center;">No.</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600;">Course</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; text-align: center;">Code</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; text-align: center;">C.H</th>
                                            <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600;">Pre-Requisites</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="elective_reqs" t-as="req">
                                            <tr t-attf-style="background-color: {{ req_index % 2 == 0 and '#f9f9f9' or '#ffffff' }};">
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;">
                                                    <span t-esc="req_index + 1"/>
                                                </td>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px;" t-esc="req.course_id.name if req.course_id else ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;" t-esc="req.course_code or ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;" t-esc="req.course_credit_hours or ''"/>
                                                <td style="border: 1px solid #e0e0e0; padding: 12px 10px;" t-esc="req.course_prerequisite or '-'"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>

                    </div>
                </main>
            </t>
        </t>
    </template>

    <!-- Semesters Report Template -->
    <template id="department_semesters_report_template">
        <t t-call="elearning_colleges.external_layout_no_header_footer_dept">
            <t t-foreach="docs" t-as="doc">
                 <main>
                    <div style="font-family: DejaVu Sans, Arial, Tahoma; padding: 15px; margin: 0; position: relative;">
                        
                        <!-- Top Section: Logo (Right) and Info (Left) -->
                        <!-- Right Side: UST Logo - Positioned absolutely at top right -->
                        <div style="position: absolute; top: 0; right: 0; text-align: right;">
                            <img t-attf-src="/elearning_colleges/static/src/img/ust_en.png"
                                 alt="UST Logo"
                                 style="width: 200px; height: auto; max-width: 200px;"/>
                        </div>
                        
                        <!-- Left Side: College, Department, Academic Year, Credit Hours -->
                        <div style="width: 60%; margin-bottom: 30px;">
                            <div style="font-size: 18px; font-weight: bold; margin-bottom: 5px;" t-esc="doc.college_id.name if doc.college_id else ''"/>
                            <div style="font-size: 16px; margin-bottom: 5px;" t-esc="doc.name or ''"/>
                            <div style="font-size: 14px; margin-bottom: 5px;">
                                Academic Year: <span t-esc="doc.academic_year_start or ''"/> / <span t-esc="doc.academic_year_end or ''"/>
                            </div>
                            <div style="font-size: 14px;">
                                <t t-set="total_sem_ch" t-value="0"/>
                                <t t-foreach="doc.semester_ids" t-as="s">
                                    <t t-set="ch" t-value="int(s.course_credit_hours) if s.course_credit_hours else 0"/>
                                    <t t-set="total_sem_ch" t-value="total_sem_ch + ch"/>
                                </t>
                                Total Credit Hours: <span t-esc="total_sem_ch"/>
                            </div>
                        </div>

                        <!-- Semesters Sections -->
                        <t t-set="sorted_keys" t-value="['Y1S1', 'Y1S2', 'Y2S1', 'Y2S2', 'Y3S1', 'Y3S2', 'Y4S1', 'Y4S2', 'Y5S1', 'Y5S2', 'Y6S1', 'Y6S2']"/>
                        <t t-foreach="sorted_keys" t-as="sem_key">
                            <t t-if="sem_key == 'Y1S1'">
                                <t t-set="sems" t-value="doc.y1s1_semester_ids"/>
                            </t>
                            <t t-elif="sem_key == 'Y1S2'">
                                <t t-set="sems" t-value="doc.y1s2_semester_ids"/>
                            </t>
                            <t t-elif="sem_key == 'Y2S1'">
                                <t t-set="sems" t-value="doc.y2s1_semester_ids"/>
                            </t>
                            <t t-elif="sem_key == 'Y2S2'">
                                <t t-set="sems" t-value="doc.y2s2_semester_ids"/>
                            </t>
                            <t t-elif="sem_key == 'Y3S1'">
                                <t t-set="sems" t-value="doc.y3s1_semester_ids"/>
                            </t>
                            <t t-elif="sem_key == 'Y3S2'">
                                <t t-set="sems" t-value="doc.y3s2_semester_ids"/>
                            </t>
                            <t t-elif="sem_key == 'Y4S1'">
                                <t t-set="sems" t-value="doc.y4s1_semester_ids"/>
                            </t>
                            <t t-elif="sem_key == 'Y4S2'">
                                <t t-set="sems" t-value="doc.y4s2_semester_ids"/>
                            </t>
                            <t t-elif="sem_key == 'Y5S1'">
                                <t t-set="sems" t-value="doc.y5s1_semester_ids"/>
                            </t>
                            <t t-elif="sem_key == 'Y5S2'">
                                <t t-set="sems" t-value="doc.y5s2_semester_ids"/>
                            </t>
                            <t t-elif="sem_key == 'Y6S1'">
                                <t t-set="sems" t-value="doc.y6s1_semester_ids"/>
                            </t>
                            <t t-elif="sem_key == 'Y6S2'">
                                <t t-set="sems" t-value="doc.y6s2_semester_ids"/>
                            </t>
                            <t t-if="sems">
                                <t t-set="sem_ch" t-value="0"/>
                                <t t-foreach="sems" t-as="s">
                                    <t t-set="ch" t-value="int(s.course_credit_hours) if s.course_credit_hours else 0"/>
                                    <t t-set="sem_ch" t-value="sem_ch + ch"/>
                                </t>
                                <div style="margin-bottom: 30px;">
                                    <h3 style="color: #1a5276; padding: 10px 15px; margin: 0 0 15px 0; font-size: 20px; font-weight: 600;">
                                        <span t-esc="sem_key"/> (<span t-esc="sem_ch"/> Credit Hours)
                                    </h3>
                                    <table style="width: 100%; border-collapse: collapse; border-radius: 5px; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                                        <thead>
                                            <tr style="background-color: #2980b9; color: white;">
                                                <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; width: 5%; text-align: center;">No.</th>
                                                <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600;">Course</th>
                                                <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; text-align: center;">Code</th>
                                                <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; text-align: center;">C.H</th>
                                                <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600;">Pre-Requisites</th>
                                                <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; text-align: center;">Course Outline (EN)</th>
                                                <th style="border: 1px solid #e0e0e0; padding: 12px 10px; font-weight: 600; text-align: center;">Course Outline (AR)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="sems" t-as="sem">
                                                <tr t-attf-style="background-color: {{ sem_index % 2 == 0 and '#f9f9f9' or '#ffffff' }};">
                                                    <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;">
                                                        <span t-esc="sem_index + 1"/>
                                                    </td>
                                                    <td style="border: 1px solid #e0e0e0; padding: 12px 10px;" t-esc="sem.course_id.name if sem.course_id else ''"/>
                                                    <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;" t-esc="sem.course_code or ''"/>
                                                    <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;" t-esc="sem.course_credit_hours or ''"/>
                                                    <td style="border: 1px solid #e0e0e0; padding: 12px 10px;" t-esc="sem.course_prerequisite or '-'"/>
                                                    <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;">
                                                        <t t-if="sem.course_id">
                                                            <a t-attf-href="/course-outline/{{ sem.course_id.id }}/pdf" style="color: #1a5276; text-decoration: none; font-weight: 400;">View Outline</a>
                                                        </t>
                                                        <t t-else="">
                                                            <span>-</span>
                                                        </t>
                                                    </td>
                                                    <td style="border: 1px solid #e0e0e0; padding: 12px 10px; text-align: center;">
